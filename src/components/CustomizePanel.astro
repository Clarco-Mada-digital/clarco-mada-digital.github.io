---
// Personnaliseur visiteur : ambiance (clair/sombre) + police + palette.
// Piloté par portfolioApp (customizeOpen, fontPairings, colorThemes,
// setFont, setPalette, toggleTheme, resetCustomize).
---

<!-- Bouton flottant (pilule, libellé visible pour la découvrabilité) -->
<button
  type="button"
  @click="customizeOpen = true"
  x-show="!customizeOpen"
  aria-label="Personnaliser l'apparence"
  class="fixed bottom-5 right-5 z-40 flex items-center gap-2 pl-3.5 pr-4 py-3 rounded-full bg-gradient-to-br from-neon-cyan to-neon-purple text-lab-dark font-bold text-sm shadow-xl shadow-neon-cyan/20 hover:scale-105 active:scale-95 transition-transform"
>
  <span class="relative flex items-center justify-center">
    <span
      class="absolute inline-flex h-full w-full rounded-full bg-lab-dark/30 animate-ping"
    ></span>
    <svg class="w-5 h-5 relative" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <circle cx="12" cy="12" r="3"></circle>
      <path
        d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"
      ></path>
    </svg>
  </span>
  <span class="hidden sm:inline">Personnaliser</span>
</button>

<!-- Backdrop -->
<div
  x-show="customizeOpen"
  x-cloak
  x-transition.opacity
  @click="customizeOpen = false"
  class="fixed inset-0 z-40 bg-lab-dark/50 backdrop-blur-[2px]"
  style="display:none"
>
</div>

<!-- Panneau -->
<aside
  x-show="customizeOpen"
  x-cloak
  x-transition:enter="transition ease-out duration-300"
  x-transition:enter-start="translate-x-full"
  x-transition:enter-end="translate-x-0"
  x-transition:leave="transition ease-in duration-200"
  x-transition:leave-start="translate-x-0"
  x-transition:leave-end="translate-x-full"
  @keydown.escape.window="customizeOpen = false"
  class="fixed top-0 right-0 z-50 h-screen w-full sm:w-[340px] bg-lab-card border-l border-lab-border overflow-y-auto"
  style="display:none"
>
  <!-- En-tête -->
  <div
    class="sticky top-0 bg-lab-card/95 backdrop-blur-md border-b border-lab-border px-5 py-4 flex items-center justify-between z-10"
  >
    <div class="flex items-center gap-2.5">
      <span
        class="w-8 h-8 rounded-lg bg-gradient-to-br from-neon-cyan to-neon-purple flex items-center justify-center text-lab-dark"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="3"></circle>
          <path d="M12 1v4M12 19v4M4.2 4.2l2.8 2.8M17 17l2.8 2.8M1 12h4M19 12h4M4.2 19.8 7 17M17 7l2.8-2.8"></path>
        </svg>
      </span>
      <div>
        <div class="text-white font-bold leading-none">Personnaliser</div>
        <div class="text-gray-500 text-[10px] font-mono mt-1">mémorisé sur cet appareil</div>
      </div>
    </div>
    <button
      type="button"
      @click="customizeOpen = false"
      aria-label="Fermer"
      class="w-8 h-8 rounded-lg bg-lab-dark flex items-center justify-center text-gray-400 hover:text-white transition-colors"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path d="M18 6L6 18M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <div class="p-5 space-y-7">
    <!-- Ambiance : segmenté Sombre / Clair -->
    <section>
      <div class="text-[11px] text-gray-500 uppercase tracking-wider mb-2.5 font-mono">Ambiance</div>
      <div class="grid grid-cols-2 gap-1.5 p-1.5 bg-lab-dark rounded-xl border border-lab-border">
        <button
          type="button"
          @click="if (isLight) toggleTheme()"
          class="py-2.5 rounded-lg text-sm font-semibold flex items-center justify-center gap-2 transition-colors"
          :class="!isLight ? 'bg-lab-card text-neon-cyan shadow-inner' : 'text-gray-500 hover:text-gray-300'"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
          </svg>
          Sombre
        </button>
        <button
          type="button"
          @click="if (!isLight) toggleTheme()"
          class="py-2.5 rounded-lg text-sm font-semibold flex items-center justify-center gap-2 transition-colors"
          :class="isLight ? 'bg-white text-lab-dark shadow' : 'text-gray-500 hover:text-gray-300'"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path>
          </svg>
          Clair
        </button>
      </div>
    </section>

    <!-- Police -->
    <section>
      <div class="text-[11px] text-gray-500 uppercase tracking-wider mb-2.5 font-mono">Police</div>
      <div class="grid grid-cols-2 gap-2.5">
        <template x-for="f in fontPairings" :key="f.id">
          <button
            type="button"
            @click="setFont(f.id)"
            class="relative text-left px-3.5 py-3 rounded-xl bg-lab-dark border-2 transition-all"
            :class="fontId === f.id ? 'border-neon-cyan' : 'border-lab-border hover:border-gray-600'"
          >
            <span
              x-show="fontId === f.id"
              class="absolute top-2 right-2 w-2 h-2 rounded-full bg-neon-cyan"
            ></span>
            <div class="text-white text-xl leading-tight" :style="'font-family:' + f.sans" x-text="f.label"></div>
            <div class="text-gray-500 text-[11px] mt-1.5" :style="'font-family:' + f.mono">const x = 42;</div>
          </button>
        </template>
      </div>
    </section>

    <!-- Palette -->
    <section>
      <div class="text-[11px] text-gray-500 uppercase tracking-wider mb-2.5 font-mono">Palette</div>
      <div class="space-y-2">
        <template x-for="t in colorThemes" :key="t.id">
          <button
            type="button"
            @click="setPalette(t.id)"
            class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl bg-lab-dark border-2 transition-all"
            :class="paletteId === t.id ? 'border-neon-cyan' : 'border-lab-border hover:border-gray-600'"
          >
            <span
              class="h-7 w-14 rounded-md shrink-0 border border-white/10"
              :style="'background: linear-gradient(135deg, rgb(' + t.cyan + '), rgb(' + t.purple + '))'"
            ></span>
            <span class="flex gap-1">
              <span class="w-2.5 h-2.5 rounded-full" :style="'background: rgb(' + t.green + ')'"></span>
            </span>
            <span class="text-sm text-gray-200 font-medium" x-text="t.label"></span>
            <svg
              x-show="paletteId === t.id"
              class="ml-auto w-4 h-4 text-neon-cyan"
              fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"
            >
              <path d="M20 6 9 17l-5-5"></path>
            </svg>
          </button>
        </template>
      </div>
    </section>

    <button
      type="button"
      @click="resetCustomize()"
      class="w-full py-2.5 rounded-xl border border-lab-border text-gray-400 text-sm font-mono hover:text-neon-cyan hover:border-neon-cyan transition-colors flex items-center justify-center gap-2"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path d="M3 12a9 9 0 1 0 3-6.7L3 8"></path><path d="M3 3v5h5"></path>
      </svg>
      Réinitialiser
    </button>
  </div>
</aside>

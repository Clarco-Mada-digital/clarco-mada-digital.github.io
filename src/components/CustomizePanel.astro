---
// Personnaliseur visiteur : police + palette. Piloté par portfolioApp
// (customizeOpen, fontPairings, colorThemes, setFont, setPalette).
---

<!-- Bouton flottant -->
<button
  @click="customizeOpen = !customizeOpen"
  aria-label="Personnaliser l'apparence"
  class="fixed bottom-6 right-6 z-40 w-12 h-12 rounded-full bg-gradient-to-br from-neon-cyan to-neon-purple text-lab-dark flex items-center justify-center shadow-lg hover:scale-110 transition-transform"
  :class="customizeOpen ? 'rotate-90' : ''"
>
  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
    <circle cx="12" cy="12" r="3"></circle>
    <path
      d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"
    ></path>
  </svg>
</button>

<!-- Backdrop -->
<div
  x-show="customizeOpen"
  x-cloak
  x-transition.opacity
  @click="customizeOpen = false"
  class="fixed inset-0 z-40 bg-lab-dark/40 backdrop-blur-[2px]"
  style="display:none"
>
</div>

<!-- Panneau -->
<aside
  x-show="customizeOpen"
  x-cloak
  x-transition:enter="transition ease-out duration-300"
  x-transition:enter-start="translate-x-full"
  x-transition:enter-end="translate-x-0"
  x-transition:leave="transition ease-in duration-200"
  x-transition:leave-start="translate-x-0"
  x-transition:leave-end="translate-x-full"
  @keydown.escape.window="customizeOpen = false"
  class="fixed top-0 right-0 z-50 h-screen w-full sm:w-80 bg-lab-card border-l border-lab-border overflow-y-auto p-6"
  style="display:none"
>
  <div class="flex items-center justify-between mb-1">
    <h3 class="text-white font-bold text-lg">Personnaliser</h3>
    <button
      @click="customizeOpen = false"
      aria-label="Fermer"
      class="w-8 h-8 rounded-lg bg-lab-dark flex items-center justify-center text-gray-400 hover:text-white transition-colors"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path d="M18 6L6 18M6 6l12 12"></path>
      </svg>
    </button>
  </div>
  <p class="text-gray-500 text-xs font-mono mb-6">Ton choix est mémorisé sur cet appareil.</p>

  <!-- Thème clair / sombre -->
  <div class="mb-7">
    <div class="text-[11px] text-gray-500 uppercase tracking-wider mb-3">Ambiance</div>
    <button
      @click="toggleTheme()"
      class="w-full flex items-center justify-between px-4 py-3 rounded-xl bg-lab-dark border border-lab-border hover:border-neon-cyan transition-colors"
    >
      <span class="text-sm text-gray-300" x-text="isLight ? 'Mode clair' : 'Mode sombre'"></span>
      <span class="text-neon-cyan" x-text="isLight ? '☀' : '☾'"></span>
    </button>
  </div>

  <!-- Polices -->
  <div class="mb-7">
    <div class="text-[11px] text-gray-500 uppercase tracking-wider mb-3">Police</div>
    <div class="grid grid-cols-2 gap-2">
      <template x-for="f in fontPairings" :key="f.id">
        <button
          @click="setFont(f.id)"
          class="text-left px-3 py-3 rounded-xl bg-lab-dark border transition-colors"
          :class="fontId === f.id ? 'border-neon-cyan' : 'border-lab-border hover:border-gray-600'"
        >
          <div class="text-white text-lg leading-tight" :style="'font-family:' + f.sans" x-text="f.label"></div>
          <div class="text-gray-500 text-[11px] mt-1" :style="'font-family:' + f.mono">Aa Bb 123 {}</div>
        </button>
      </template>
    </div>
  </div>

  <!-- Palette -->
  <div class="mb-7">
    <div class="text-[11px] text-gray-500 uppercase tracking-wider mb-3">Palette de couleurs</div>
    <div class="space-y-2">
      <template x-for="t in colorThemes" :key="t.id">
        <button
          @click="setPalette(t.id)"
          class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl bg-lab-dark border transition-colors"
          :class="paletteId === t.id ? 'border-neon-cyan' : 'border-lab-border hover:border-gray-600'"
        >
          <span class="flex gap-1.5">
            <span class="w-4 h-4 rounded-full" :style="'background: rgb(' + t.cyan + ')'"></span>
            <span class="w-4 h-4 rounded-full" :style="'background: rgb(' + t.purple + ')'"></span>
            <span class="w-4 h-4 rounded-full" :style="'background: rgb(' + t.green + ')'"></span>
          </span>
          <span class="text-sm text-gray-300" x-text="t.label"></span>
          <span x-show="paletteId === t.id" class="ml-auto text-neon-cyan text-xs">●</span>
        </button>
      </template>
    </div>
  </div>

  <button
    @click="resetCustomize()"
    class="w-full py-2.5 rounded-xl border border-lab-border text-gray-400 text-sm font-mono hover:text-neon-cyan hover:border-neon-cyan transition-colors"
  >
    ↺ Réinitialiser
  </button>
</aside>

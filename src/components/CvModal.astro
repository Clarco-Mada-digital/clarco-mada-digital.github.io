---
// Choix du template de CV puis génération PDF (piloté par Alpine / cv.ts).
---

<div
  x-show="cvOpen"
  x-cloak
  x-transition:enter="transition ease-out duration-300"
  x-transition:enter-start="opacity-0"
  x-transition:enter-end="opacity-100"
  x-transition:leave="transition ease-in duration-200"
  x-transition:leave-start="opacity-100"
  x-transition:leave-end="opacity-0"
  class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-lab-dark/80 backdrop-blur-sm"
  @click.self="cvOpen = false"
  @keydown.escape.window="cvOpen = false"
  style="display: none"
>
  <div
    class="bg-lab-card border border-lab-border rounded-2xl max-w-lg w-full p-6"
    x-show="cvOpen"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="opacity-0 scale-95"
    x-transition:enter-end="opacity-100 scale-100"
  >
    <div class="flex items-center justify-between mb-1">
      <h3 class="text-xl font-bold text-white">Générer mon CV</h3>
      <button
        @click="cvOpen = false"
        aria-label="Fermer"
        class="w-8 h-8 rounded-lg bg-lab-dark flex items-center justify-center text-gray-400 hover:text-white transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M18 6L6 18M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    <p class="text-gray-500 text-sm font-mono mb-4">
      Choisis un style — le PDF est créé à partir de mes données, à la volée.
    </p>

    <div class="flex gap-2 mb-5 p-1 rounded-lg bg-lab-dark border border-lab-border">
      <button
        @click="cvMode = 'complet'"
        class="flex-1 rounded-md py-2 text-xs font-mono transition-colors"
        :class="cvMode === 'complet' ? 'bg-neon-cyan/20 text-neon-cyan' : 'text-gray-500 hover:text-gray-300'"
      >
        Complet <span class="opacity-70">(tout, 1-2 pages)</span>
      </button>
      <button
        @click="cvMode = 'simple'"
        class="flex-1 rounded-md py-2 text-xs font-mono transition-colors"
        :class="cvMode === 'simple' ? 'bg-neon-cyan/20 text-neon-cyan' : 'text-gray-500 hover:text-gray-300'"
      >
        Simple <span class="opacity-70">(condensé, 1 page)</span>
      </button>
    </div>

    <!-- Liste scrollable : avec 8 styles, la modale débordait de l'écran. -->
    <div class="space-y-3 max-h-[46vh] overflow-y-auto pr-1.5 cv-list-scroll">
      <template x-for="tpl in cvTemplates" :key="tpl.id">
        <button
          @click="generateCv(tpl.id)"
          :disabled="cvBusy"
          class="w-full flex items-center gap-4 p-4 bg-lab-dark border border-lab-border rounded-xl text-left hover:border-neon-cyan transition-all disabled:opacity-50 group"
        >
          <div
            class="w-10 h-12 rounded-md flex items-center justify-center shrink-0 text-white"
            :style="'background:' + tpl.color"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <div class="text-white font-bold group-hover:text-neon-cyan transition-colors" x-text="tpl.label"></div>
            <div class="text-gray-500 text-xs" x-text="tpl.description"></div>
          </div>
          <div class="font-mono text-xs">
            <span x-show="cvBusy !== tpl.id" class="text-gray-600">PDF ↓</span>
            <span x-show="cvBusy === tpl.id" style="display:none" class="text-neon-cyan">…</span>
          </div>
        </button>
      </template>

      <!-- CV importé (optionnel, défini dans l'admin) -->
      <template x-if="customCv">
        <a
          :href="asset(customCv)"
          download
          target="_blank"
          rel="noopener noreferrer"
          class="w-full flex items-center gap-4 p-4 bg-lab-dark border border-neon-green/30 rounded-xl text-left hover:border-neon-green transition-all"
        >
          <div class="w-10 h-12 rounded-md border border-neon-green/30 flex items-center justify-center shrink-0 text-neon-green">📎</div>
          <div class="flex-1">
            <div class="text-white font-bold">Mon CV importé</div>
            <div class="text-gray-500 text-xs">Le fichier PDF que j'ai fourni</div>
          </div>
          <span class="font-mono text-xs text-gray-600">↓</span>
        </a>
      </template>
    </div>
  </div>
</div>

<style>
  /* Scrollbar discrète, assortie au thème sombre de la modale. */
  .cv-list-scroll {
    scrollbar-width: thin;
    scrollbar-color: rgba(148, 163, 184, 0.35) transparent;
  }
  .cv-list-scroll::-webkit-scrollbar {
    width: 6px;
  }
  .cv-list-scroll::-webkit-scrollbar-thumb {
    background: rgba(148, 163, 184, 0.35);
    border-radius: 3px;
  }
</style>

---
// Modal Labs : démo agrandie (iframe sandboxé) + onglets pour voir le code.
// Piloté par Alpine (selectedLab, labTab, labSrcdoc, openLab/closeLab).
---

<div
  x-show="selectedLab"
  x-cloak
  x-transition:enter="transition ease-out duration-300"
  x-transition:enter-start="opacity-0"
  x-transition:enter-end="opacity-100"
  x-transition:leave="transition ease-in duration-200"
  x-transition:leave-start="opacity-100"
  x-transition:leave-end="opacity-0"
  @click.self="closeLab()"
  @keydown.escape.window="closeLab()"
  class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-lab-dark/85 backdrop-blur-sm"
  style="display: none"
>
  <div
    class="bg-lab-card border border-lab-border rounded-2xl w-full max-w-3xl max-h-[90vh] flex flex-col overflow-hidden"
    x-show="selectedLab"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="opacity-0 scale-95"
    x-transition:enter-end="opacity-100 scale-100"
  >
    <template x-if="selectedLab">
      <div class="flex flex-col min-h-0">
        <!-- En-tête -->
        <div class="flex items-center justify-between px-5 py-3.5 border-b border-lab-border">
          <h3 class="text-white font-bold flex items-center gap-2 min-w-0">
            <span x-text="selectedLab.emoji"></span>
            <span class="truncate" x-text="selectedLab.title"></span>
          </h3>
          <button
            @click="closeLab()"
            aria-label="Fermer"
            class="w-8 h-8 shrink-0 rounded-lg bg-lab-dark flex items-center justify-center text-gray-400 hover:text-white transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M18 6L6 18M6 6l12 12"></path>
            </svg>
          </button>
        </div>

        <!-- Onglets -->
        <div class="flex gap-1 px-3 pt-3 border-b border-lab-border bg-lab-dark/40">
          <template x-for="tab in [['result','▶ Résultat'],['html','HTML'],['css','CSS'],['js','JS']]" :key="tab[0]">
            <button
              @click="labTab = tab[0]"
              class="px-3 py-2 text-xs font-mono rounded-t-md transition-colors"
              :class="labTab === tab[0] ? 'text-neon-cyan bg-lab-card border border-b-0 border-lab-border' : 'text-gray-500 hover:text-gray-300'"
              x-text="tab[1]"
            ></button>
          </template>
        </div>

        <!-- Contenu des onglets -->
        <div class="flex-1 min-h-0 overflow-hidden">
          <!-- Résultat : iframe live (reste monté pour ne pas relancer la démo) -->
          <div x-show="labTab === 'result'" class="h-[60vh] bg-lab-dark">
            <iframe
              :title="'Démo : ' + selectedLab.title"
              sandbox="allow-scripts"
              :srcdoc="labSrcdoc"
              class="w-full h-full block"
            ></iframe>
          </div>

          <!-- Code -->
          <template x-for="key in ['html','css','js']" :key="key">
            <div x-show="labTab === key" class="h-[60vh] overflow-auto">
              <pre class="p-4 text-xs font-mono text-gray-300 whitespace-pre-wrap break-words"><code x-text="(selectedLab.demo && selectedLab.demo[key]) || '— vide —'"></code></pre>
            </div>
          </template>
        </div>
      </div>
    </template>
  </div>
</div>

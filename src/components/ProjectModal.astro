---
// Modale projet : pilotée par Alpine (selectedProject). Les données viennent
// du tableau `projects` injecté dans le composant portfolioApp.
---

<div
  x-show="selectedProject"
  x-cloak
  x-transition:enter="transition ease-out duration-300"
  x-transition:enter-start="opacity-0"
  x-transition:enter-end="opacity-100"
  x-transition:leave="transition ease-in duration-200"
  x-transition:leave-start="opacity-100"
  x-transition:leave-end="opacity-0"
  class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-lab-dark/80 backdrop-blur-sm"
  @click.self="selectedProject = null"
  @keydown.escape.window="!lightbox && (selectedProject = null)"
  style="display: none"
>
  <div
    class="bg-lab-card border border-lab-border rounded-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto"
    x-show="selectedProject"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="opacity-0 scale-95"
    x-transition:enter-end="opacity-100 scale-100"
  >
    <template x-if="selectedProject">
      <div>
        <!-- Header gradient -->
        <div
          class="h-40 relative overflow-hidden rounded-t-2xl"
          :class="selectedProject.gradient"
        >
          <img
            x-show="selectedProject.cover"
            :src="asset(selectedProject.cover)"
            :alt="'Couverture du projet ' + selectedProject.name"
            class="absolute inset-0 w-full h-full object-cover"
          />
          <div class="absolute inset-0 bg-lab-dark/30"></div>
          <button
            @click="selectedProject = null"
            aria-label="Fermer"
            class="absolute top-4 right-4 w-8 h-8 rounded-lg bg-lab-dark/80 flex items-center justify-center text-gray-400 hover:text-white hover:bg-lab-dark transition-colors"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path d="M18 6L6 18M6 6l12 12"></path>
            </svg>
          </button>
          <div class="absolute bottom-4 left-6">
            <div
              class="text-xs font-mono text-neon-cyan mb-1"
              x-text="selectedProject.year"
            >
            </div>
            <h3
              class="text-3xl font-extrabold text-white"
              x-text="selectedProject.name"
            >
            </h3>
          </div>
        </div>

        <!-- Content -->
        <div class="p-6">
          <p
            class="text-gray-400 leading-relaxed mb-6"
            x-text="selectedProject.fullDesc"
          >
          </p>

          <div class="mb-6">
            <h4
              class="text-xs text-gray-500 font-mono uppercase tracking-wider mb-3"
            >
              Fonctionnalités clés
            </h4>
            <ul class="space-y-1.5">
              <template
                x-for="feature in selectedProject.features"
                :key="feature"
              >
                <li class="flex items-start gap-2 text-sm text-gray-300">
                  <span class="text-neon-cyan mt-0.5">▸</span>
                  <span x-text="feature"></span>
                </li>
              </template>
            </ul>
          </div>

          <div class="mb-6" x-show="galleryAll.length">
            <h4
              class="text-xs text-gray-500 font-mono uppercase tracking-wider mb-3"
            >
              Galerie
            </h4>
            <div class="grid grid-cols-3 gap-2">
              <template x-for="(img, gi) in galleryAll" :key="gi">
                <button
                  type="button"
                  @click="openImageAt(gi)"
                  class="block group/g"
                >
                  <img
                    :src="img"
                    loading="lazy"
                    alt="Aperçu du projet"
                    class="w-full h-20 object-cover rounded-md border border-lab-border group-hover/g:border-neon-cyan transition-colors"
                  />
                </button>
              </template>
            </div>
          </div>

          <div class="mb-6">
            <h4
              class="text-xs text-gray-500 font-mono uppercase tracking-wider mb-3"
            >
              Stack technique
            </h4>
            <div class="flex flex-wrap gap-2">
              <template x-for="tag in selectedProject.tags" :key="tag">
                <span
                  class="px-3 py-1 bg-lab-dark border border-lab-border rounded-md text-xs font-mono text-neon-cyan"
                  x-text="tag"
                >
                </span>
              </template>
            </div>
          </div>

          <div class="flex gap-3">
            <a
              :href="selectedProject.repoUrl || '#'"
              x-show="selectedProject.repoUrl"
              target="_blank"
              rel="noopener noreferrer"
              class="flex-1 py-2.5 bg-neon-cyan text-lab-dark font-bold text-center rounded-lg text-sm hover:bg-white transition-colors"
              >Voir le code</a
            >
            <a
              :href="selectedProject.demoUrl || '#'"
              x-show="selectedProject.demoUrl"
              target="_blank"
              rel="noopener noreferrer"
              class="flex-1 py-2.5 border border-lab-border text-gray-300 font-bold text-center rounded-lg text-sm hover:border-neon-cyan hover:text-neon-cyan transition-all"
              >Démo live</a
            >
            <span
              x-show="!selectedProject.repoUrl && !selectedProject.demoUrl"
              class="flex-1 py-2.5 text-center text-gray-600 text-sm font-mono"
              >Liens à venir</span
            >
          </div>
        </div>
      </div>
    </template>
  </div>
</div>

<!-- Lightbox : agrandit une image de la galerie, navigable au clavier -->
<div
  x-show="lightbox"
  x-cloak
  x-transition.opacity
  @click.self="closeLightbox()"
  @keydown.escape.window="closeLightbox()"
  @keydown.arrow-right.window="nextImage()"
  @keydown.arrow-left.window="prevImage()"
  class="fixed inset-0 z-[60] flex items-center justify-center p-4 bg-lab-dark/90 backdrop-blur-sm"
  style="display: none"
>
  <!-- Bouton précédent -->
  <button
    type="button"
    x-show="lightboxImages.length > 1"
    @click.stop="prevImage()"
    aria-label="Image précédente"
    class="absolute left-3 md:left-6 top-1/2 -translate-y-1/2 w-11 h-11 rounded-full bg-lab-card/80 border border-lab-border flex items-center justify-center text-gray-300 hover:text-neon-cyan hover:border-neon-cyan transition-colors z-10"
  >
    <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path d="M15 18l-6-6 6-6"></path>
    </svg>
  </button>

  <!-- Image + compteur -->
  <div
    class="relative flex flex-col items-center gap-3"
    @click.stop
    @touchstart.passive="onTouchStart($event)"
    @touchend.passive="onTouchEnd($event)"
  >
    <img
      :src="lightbox"
      alt="Image agrandie"
      draggable="false"
      class="max-w-full max-h-[82vh] rounded-lg border border-lab-border select-none"
    />
    <div
      x-show="lightboxImages.length > 1"
      class="px-3 py-1 rounded-full bg-lab-card/80 border border-lab-border text-xs font-mono text-gray-300"
    >
      <span x-text="lightboxIndex + 1"></span> / <span x-text="lightboxImages.length"></span>
    </div>
  </div>

  <!-- Bouton suivant -->
  <button
    type="button"
    x-show="lightboxImages.length > 1"
    @click.stop="nextImage()"
    aria-label="Image suivante"
    class="absolute right-3 md:right-6 top-1/2 -translate-y-1/2 w-11 h-11 rounded-full bg-lab-card/80 border border-lab-border flex items-center justify-center text-gray-300 hover:text-neon-cyan hover:border-neon-cyan transition-colors z-10"
  >
    <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path d="M9 18l6-6-6-6"></path>
    </svg>
  </button>

  <!-- Bouton fermer -->
  <button
    type="button"
    @click.stop="closeLightbox()"
    aria-label="Fermer"
    class="absolute top-4 right-4 w-9 h-9 rounded-lg bg-lab-card/80 border border-lab-border flex items-center justify-center text-gray-400 hover:text-white transition-colors z-10"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path d="M18 6L6 18M6 6l12 12"></path>
    </svg>
  </button>
</div>

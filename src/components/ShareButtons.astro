---
/**
 * Boutons de partage d'un article (réseaux sociaux + copie + partage natif).
 * 100 % sans dépendance externe : les réseaux sont de simples liens d'intention
 * (compatibles CSP), le partage natif et la copie utilisent l'API du navigateur.
 *
 * NB : sur les réseaux, c'est l'aperçu Open Graph (couverture + titre + description)
 * qui s'affiche — on ne peut pas y publier le texte intégral de l'article.
 */
interface Props {
  url: string; // URL absolue de l'article
  title: string;
  description?: string;
}
const { url, title, description = "" } = Astro.props;

const u = encodeURIComponent(url);
const t = encodeURIComponent(title);
const txt = encodeURIComponent(`${title}\n\n${url}`);
const mail = `mailto:?subject=${t}&body=${encodeURIComponent(`${description || title}\n\n${url}`)}`;

// Réseaux : liens d'intention (s'ouvrent dans un nouvel onglet).
const networks = [
  {
    id: "x",
    label: "X",
    href: `https://twitter.com/intent/tweet?text=${t}&url=${u}`,
    path: "M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z",
  },
  {
    id: "linkedin",
    label: "LinkedIn",
    href: `https://www.linkedin.com/sharing/share-offsite/?url=${u}`,
    path: "M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z",
  },
  {
    id: "facebook",
    label: "Facebook",
    href: `https://www.facebook.com/sharer/sharer.php?u=${u}`,
    path: "M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z",
  },
  {
    id: "whatsapp",
    label: "WhatsApp",
    href: `https://wa.me/?text=${txt}`,
    path: "M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.945C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.518 5.26l-.999 3.648 3.97-1.607zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413z",
  },
  {
    id: "telegram",
    label: "Telegram",
    href: `https://t.me/share/url?url=${u}&text=${t}`,
    path: "M11.944 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0a12 12 0 00-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 01.171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z",
  },
  {
    id: "email",
    label: "E-mail",
    href: mail,
    path: "M0 3v18h24V3H0zm21.518 2L12 12.713 2.482 5h19.036zM2 7.183l7.81 6.317L2 19.812V7.183zm.18 12.817l7.34-6.067L12 15.287l2.48-1.354 7.34 6.067H2.18zM22 19.812l-7.81-6.312L22 7.183v12.629z",
  },
];
---

<div
  class="mt-10 pt-6 border-t border-lab-border"
  data-share
  data-url={url}
  data-title={title}
  data-text={description || title}
>
  <p class="text-xs font-mono text-gray-500 mb-3">
    <span class="text-neon-cyan">share()</span> — ça t'a parlé&nbsp;? Fais tourner&nbsp;:
  </p>
  <div class="flex flex-wrap items-center gap-2">
    {
      networks.map((n) => (
        <a
          href={n.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`Partager sur ${n.label}`}
          title={`Partager sur ${n.label}`}
          class="group inline-flex items-center justify-center w-10 h-10 rounded-lg border border-lab-border text-gray-400 hover:text-neon-cyan hover:border-neon-cyan transition-all"
        >
          <svg
            viewBox="0 0 24 24"
            class="w-4 h-4 fill-current"
            aria-hidden="true"
          >
            <path d={n.path} />
          </svg>
        </a>
      ))
    }

    {/* Copier le lien (JS) */}
    <button
      type="button"
      data-share-copy
      aria-label="Copier le lien"
      title="Copier le lien"
      class="group inline-flex items-center justify-center gap-2 h-10 px-3 rounded-lg border border-lab-border text-gray-400 font-mono text-xs hover:text-neon-green hover:border-neon-green transition-all"
    >
      <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current" aria-hidden="true">
        <path
          d="M16 1H4a2 2 0 00-2 2v14h2V3h12V1zm3 4H8a2 2 0 00-2 2v14a2 2 0 002 2h11a2 2 0 002-2V7a2 2 0 00-2-2zm0 16H8V7h11v14z"
        ></path>
      </svg>
      <span data-share-copy-label>Copier le lien</span>
    </button>

    {/* Partage natif (téléphone) — révélé par JS si l'API existe */}
    <button
      type="button"
      data-share-native
      hidden
      aria-label="Partager…"
      title="Partager…"
      class="group inline-flex items-center justify-center gap-2 h-10 px-3 rounded-lg border border-neon-cyan/40 text-neon-cyan font-mono text-xs hover:bg-neon-cyan/10 transition-all"
    >
      <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current" aria-hidden="true">
        <path
          d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92s2.92-1.31 2.92-2.92-1.31-2.92-2.92-2.92z"
        ></path>
      </svg>
      Partager…
    </button>
  </div>
</div>

<script>
  // Progressive enhancement : copie + partage natif. Sans JS, les liens réseaux
  // fonctionnent quand même.
  document.querySelectorAll<HTMLElement>("[data-share]").forEach((box) => {
    const url = box.dataset.url || location.href;
    const title = box.dataset.title || document.title;
    const text = box.dataset.text || "";

    const copyBtn = box.querySelector<HTMLButtonElement>("[data-share-copy]");
    const copyLabel = box.querySelector<HTMLElement>("[data-share-copy-label]");
    copyBtn?.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(url);
        if (copyLabel) {
          const prev = copyLabel.textContent;
          copyLabel.textContent = "✓ Lien copié";
          setTimeout(() => (copyLabel.textContent = prev), 1800);
        }
      } catch {
        /* clipboard indisponible (http non sécurisé…) : on ignore */
      }
    });

    const nativeBtn = box.querySelector<HTMLButtonElement>("[data-share-native]");
    if (nativeBtn && typeof navigator.share === "function") {
      nativeBtn.hidden = false;
      nativeBtn.addEventListener("click", () => {
        navigator.share({ title, text, url }).catch(() => {});
      });
    }
  });
</script>

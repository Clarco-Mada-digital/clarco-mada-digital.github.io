---
import { content } from "../lib/content";
import { NAV_ITEMS } from "../lib/nav";

const { site, socials } = content;
const year = new Date().getFullYear();
---

<aside
  class="md:w-64 md:h-screen md:sticky top-0 border-r border-lab-border bg-lab-dark/90 backdrop-blur-md p-6 flex flex-col justify-between z-20"
>
  <div>
    <!-- Logo -->
    <a
      href="#"
      @click.prevent="changeView('home')"
      class="flex items-center gap-3 mb-12 group cursor-pointer"
    >
      <div
        class="w-11 h-11 rounded-xl bg-gradient-to-br from-neon-cyan to-neon-purple flex items-center justify-center text-lab-dark font-extrabold text-xl group-hover:rotate-6 transition-transform"
      >
        {site.initials}
      </div>
      <div class="font-mono text-sm">
        <div class="text-white font-bold tracking-wide">{site.handle}</div>
        {
          site.available && (
            <div class="text-neon-green text-xs flex items-center gap-1.5">
              <span class="w-2 h-2 bg-neon-green rounded-full animate-pulse" />
              {site.availabilityLabel}
            </div>
          )
        }
      </div>
    </a>

    <!-- Navigation -->
    <nav class="space-y-1 font-mono text-sm">
      {
        NAV_ITEMS.map((item) => (
          <a
            href="#"
            @click.prevent={`changeView('${item.id}')`}
            class="block py-2.5 px-4 rounded-lg transition-all duration-300 flex items-center group"
            :class={`activeView === '${item.id}' ? 'bg-lab-card text-neon-cyan shadow-inner' : 'text-gray-500 hover:text-white hover:bg-lab-card/50'`}
          >
            <span
              class="mr-3 opacity-60 group-hover:opacity-100"
              x-text={`activeView === '${item.id}' ? '▸' : '▹'`}
            />
            <span>{item.label}</span>
          </a>
        ))
      }
    </nav>
  </div>

  <!-- Socials -->
  <div class="hidden md:block mt-10">
    <div class="text-[10px] text-gray-600 uppercase tracking-[0.2em] mb-4">
      Connect
    </div>
    <div class="flex gap-4">
      <a
        href={socials.github}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="w-9 h-9 rounded-lg border border-lab-border flex items-center justify-center text-gray-500 hover:text-neon-cyan hover:border-neon-cyan transition-all"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path
            d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1-.7.1-.7.1-.7 1.2.1 1.9 1.2 1.9 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.2.5-2.3 1.3-3.1-.2-.4-.6-1.6 0-3.2 0 0 1-.3 3.4 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.7 1.6.2 2.8.1 3.2.8.8 1.3 1.9 1.3 3.2 0 4.6-2.8 5.6-5.5 5.9.5.4.9 1.2.9 2.3v3.3c0 .3.1.7.8.6A12 12 0 0 0 12 .3"
          ></path>
        </svg>
      </a>
      <a
        href={socials.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="w-9 h-9 rounded-lg border border-lab-border flex items-center justify-center text-gray-500 hover:text-neon-cyan hover:border-neon-cyan transition-all"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path
            d="M20.5 2h-17A1.5 1.5 0 0 0 2 3.5v17A1.5 1.5 0 0 0 3.5 22h17a1.5 1.5 0 0 0 1.5-1.5v-17A1.5 1.5 0 0 0 20.5 2zM8 19H5v-9h3v9zM6.5 8.3a1.8 1.8 0 1 1 0-3.5 1.8 1.8 0 0 1 0 3.5zM19 19h-3v-4.7c0-1.1 0-2.5-1.5-2.5S13 13 13 14.2V19h-3v-9h2.9v1.3a3.1 3.1 0 0 1 2.8-1.5c3 0 3.5 2 3.5 4.5V19z"
          ></path>
        </svg>
      </a>
      <a
        href={`mailto:${socials.email}`}
        aria-label="Email"
        class="w-9 h-9 rounded-lg border border-lab-border flex items-center justify-center text-gray-500 hover:text-neon-cyan hover:border-neon-cyan transition-all"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path
            d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
          ></path>
          <polyline points="22,6 12,13 2,6"></polyline>
        </svg>
      </a>
    </div>
    <p class="text-[10px] text-gray-600 mt-6 font-mono">
      © {year}
      {site.name}<br />Built with Astro, Alpine.js & Tailwind
    </p>
  </div>
</aside>

---
import { content } from "../lib/content";
import { NAV_ITEMS } from "../lib/nav";

const { site, socials } = content;
const year = new Date().getFullYear();
---

<!-- ============ BARRE MOBILE (haut) ============ -->
<header
  class="md:hidden sticky top-0 z-40 flex items-center justify-between px-5 py-3 bg-lab-dark/95 backdrop-blur-md border-b border-lab-border"
>
  <a
    href="#"
    @click.prevent="changeView('home')"
    class="flex items-center gap-2.5"
  >
    <div
      class="w-9 h-9 rounded-lg bg-gradient-to-br from-neon-cyan to-neon-purple flex items-center justify-center text-lab-dark font-extrabold"
    >
      {site.initials}
    </div>
    <div class="font-mono text-sm">
      <div class="text-white font-bold tracking-wide leading-none">
        {site.handle}
      </div>
      {
        site.available && (
          <div class="text-neon-green text-[10px] flex items-center gap-1 mt-0.5">
            <span class="w-1.5 h-1.5 bg-neon-green rounded-full animate-pulse" />
            {site.availabilityLabel}
          </div>
        )
      }
    </div>
  </a>

  <div class="flex items-center gap-2">
  <button
    @click="togglePalette()"
    aria-label="Recherche rapide"
    class="w-10 h-10 rounded-lg border border-lab-border flex items-center justify-center text-gray-300 hover:text-neon-cyan hover:border-neon-cyan transition-colors"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <circle cx="11" cy="11" r="7"></circle>
      <path d="m21 21-4.3-4.3"></path>
    </svg>
  </button>
  <button
    @click="mobileMenuOpen = !mobileMenuOpen"
    aria-label="Menu"
    :aria-expanded="mobileMenuOpen"
    class="w-10 h-10 rounded-lg border border-lab-border flex items-center justify-center text-gray-300 hover:text-neon-cyan hover:border-neon-cyan transition-colors"
  >
    <svg
      x-show="!mobileMenuOpen"
      class="w-5 h-5"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      viewBox="0 0 24 24"
    >
      <path d="M3 6h18M3 12h18M3 18h18"></path>
    </svg>
    <svg
      x-show="mobileMenuOpen"
      style="display:none"
      class="w-5 h-5"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      viewBox="0 0 24 24"
    >
      <path d="M18 6 6 18M6 6l12 12"></path>
    </svg>
  </button>
  </div>
</header>

<!-- ============ TIROIR MOBILE ============ -->
<div
  x-show="mobileMenuOpen"
  x-cloak
  @click.self="mobileMenuOpen = false"
  @keydown.escape.window="mobileMenuOpen = false"
  x-transition:enter="transition ease-out duration-200"
  x-transition:enter-start="opacity-0"
  x-transition:enter-end="opacity-100"
  x-transition:leave="transition ease-in duration-150"
  x-transition:leave-start="opacity-100"
  x-transition:leave-end="opacity-0"
  class="md:hidden fixed inset-0 z-30 bg-lab-dark/70 backdrop-blur-sm pt-16"
  style="display:none"
>
  <nav
    x-show="mobileMenuOpen"
    x-transition:enter="transition ease-out duration-250"
    x-transition:enter-start="-translate-y-4 opacity-0"
    x-transition:enter-end="translate-y-0 opacity-100"
    class="bg-lab-dark border-b border-lab-border px-5 py-5 space-y-1 font-mono text-base shadow-2xl"
  >
    {
      NAV_ITEMS.map((item) => (
        <a
          href="#"
          @click.prevent={`changeView('${item.id}')`}
          class="py-3 px-4 rounded-lg transition-all flex items-center gap-3"
          :class={`activeView === '${item.id}' ? 'bg-lab-card text-neon-cyan' : 'text-gray-400 hover:text-white hover:bg-lab-card/50'`}
        >
          <span
            class="opacity-60"
            x-text={`activeView === '${item.id}' ? '▸' : '▹'`}
          />
          <span>{item.label}</span>
        </a>
      ))
    }

    <div class="flex items-center justify-between pt-4 mt-3 border-t border-lab-border">
      <button
        @click="toggleTheme()"
        class="flex items-center gap-2 text-sm text-gray-400 hover:text-neon-cyan transition-colors"
      >
        <span
          class="w-9 h-9 rounded-lg border border-lab-border flex items-center justify-center"
        >
          <svg
            x-show="isLight"
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
          </svg>
          <svg
            x-show="!isLight"
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <circle cx="12" cy="12" r="4"></circle>
            <path
              d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"
            ></path>
          </svg>
        </span>
        <span x-text="isLight ? 'Mode sombre' : 'Mode clair'"></span>
      </button>

      <div class="flex gap-3">
        <a
          href={socials.github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="w-9 h-9 rounded-lg border border-lab-border flex items-center justify-center text-gray-500 hover:text-neon-cyan hover:border-neon-cyan transition-all"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path
              d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1-.7.1-.7.1-.7 1.2.1 1.9 1.2 1.9 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.2.5-2.3 1.3-3.1-.2-.4-.6-1.6 0-3.2 0 0 1-.3 3.4 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.7 1.6.2 2.8.1 3.2.8.8 1.3 1.9 1.3 3.2 0 4.6-2.8 5.6-5.5 5.9.5.4.9 1.2.9 2.3v3.3c0 .3.1.7.8.6A12 12 0 0 0 12 .3"
            ></path>
          </svg>
        </a>
        <a
          href={socials.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="w-9 h-9 rounded-lg border border-lab-border flex items-center justify-center text-gray-500 hover:text-neon-cyan hover:border-neon-cyan transition-all"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path
              d="M20.5 2h-17A1.5 1.5 0 0 0 2 3.5v17A1.5 1.5 0 0 0 3.5 22h17a1.5 1.5 0 0 0 1.5-1.5v-17A1.5 1.5 0 0 0 20.5 2zM8 19H5v-9h3v9zM6.5 8.3a1.8 1.8 0 1 1 0-3.5 1.8 1.8 0 0 1 0 3.5zM19 19h-3v-4.7c0-1.1 0-2.5-1.5-2.5S13 13 13 14.2V19h-3v-9h2.9v1.3a3.1 3.1 0 0 1 2.8-1.5c3 0 3.5 2 3.5 4.5V19z"
            ></path>
          </svg>
        </a>
        <a
          href={`mailto:${socials.email}`}
          aria-label="Email"
          class="w-9 h-9 rounded-lg border border-lab-border flex items-center justify-center text-gray-500 hover:text-neon-cyan hover:border-neon-cyan transition-all"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path
              d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
            ></path>
            <polyline points="22,6 12,13 2,6"></polyline>
          </svg>
        </a>
      </div>
    </div>
  </nav>
</div>

<!-- ============ SIDEBAR DESKTOP ============ -->
<aside
  class="hidden md:flex md:w-64 md:h-screen md:sticky top-0 border-r border-lab-border bg-lab-dark/90 backdrop-blur-md p-6 flex-col justify-between z-20"
>
  <div>
    <!-- Logo -->
    <a
      href="#"
      id="brand-logo"
      @click.prevent="changeView('home')"
      class="flex items-center gap-3 mb-12 group cursor-pointer"
    >
      <div
        class="w-11 h-11 rounded-xl bg-gradient-to-br from-neon-cyan to-neon-purple flex items-center justify-center text-lab-dark font-extrabold text-xl group-hover:rotate-6 transition-transform"
      >
        {site.initials}
      </div>
      <div class="font-mono text-sm">
        <div class="text-white font-bold tracking-wide">{site.handle}</div>
        {
          site.available && (
            <div class="text-neon-green text-xs flex items-center gap-1.5">
              <span class="w-2 h-2 bg-neon-green rounded-full animate-pulse" />
              {site.availabilityLabel}
            </div>
          )
        }
      </div>
    </a>

    <!-- Navigation -->
    <nav class="space-y-1 font-mono text-sm">
      {
        NAV_ITEMS.map((item) => (
          <a
            href="#"
            @click.prevent={`changeView('${item.id}')`}
            class="block py-2.5 px-4 rounded-lg transition-all duration-300 flex items-center group"
            :class={`activeView === '${item.id}' ? 'bg-lab-card text-neon-cyan shadow-inner' : 'text-gray-500 hover:text-white hover:bg-lab-card/50'`}
          >
            <span
              class="mr-3 opacity-60 group-hover:opacity-100"
              x-text={`activeView === '${item.id}' ? '▸' : '▹'`}
            />
            <span>{item.label}</span>
          </a>
        ))
      }
    </nav>

    <!-- Recherche rapide (palette ⌘K) -->
    <button
      @click="togglePalette()"
      class="mt-4 w-full flex items-center gap-2.5 py-2.5 px-4 rounded-lg border border-lab-border text-gray-500 hover:text-neon-cyan hover:border-neon-cyan/50 transition-colors font-mono text-sm"
    >
      <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <circle cx="11" cy="11" r="7"></circle>
        <path d="m21 21-4.3-4.3"></path>
      </svg>
      <span class="flex-1 text-left">Rechercher</span>
      <kbd class="text-[10px] border border-lab-border rounded px-1.5 py-0.5">⌘K</kbd>
    </button>
  </div>

  <!-- Socials -->
  <div class="mt-10">
    <!-- Bascule thème clair/sombre -->
    <button
      @click="toggleTheme()"
      class="flex items-center gap-2 mb-6 text-xs font-mono text-gray-500 hover:text-neon-cyan transition-colors"
      :aria-label="isLight ? 'Passer en mode sombre' : 'Passer en mode clair'"
    >
      <span
        class="w-9 h-9 rounded-lg border border-lab-border flex items-center justify-center"
      >
        <!-- Lune (visible en clair) -->
        <svg
          x-show="isLight"
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
        </svg>
        <!-- Soleil (visible en sombre) -->
        <svg
          x-show="!isLight"
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path
            d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"
          ></path>
        </svg>
      </span>
      <span x-text="isLight ? 'Mode sombre' : 'Mode clair'"></span>
    </button>

    <div class="text-[10px] text-gray-600 uppercase tracking-[0.2em] mb-4">
      Connect
    </div>
    <div class="flex gap-4">
      <a
        href={socials.github}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="w-9 h-9 rounded-lg border border-lab-border flex items-center justify-center text-gray-500 hover:text-neon-cyan hover:border-neon-cyan transition-all"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path
            d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1-.7.1-.7.1-.7 1.2.1 1.9 1.2 1.9 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.2.5-2.3 1.3-3.1-.2-.4-.6-1.6 0-3.2 0 0 1-.3 3.4 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.7 1.6.2 2.8.1 3.2.8.8 1.3 1.9 1.3 3.2 0 4.6-2.8 5.6-5.5 5.9.5.4.9 1.2.9 2.3v3.3c0 .3.1.7.8.6A12 12 0 0 0 12 .3"
          ></path>
        </svg>
      </a>
      <a
        href={socials.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="w-9 h-9 rounded-lg border border-lab-border flex items-center justify-center text-gray-500 hover:text-neon-cyan hover:border-neon-cyan transition-all"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path
            d="M20.5 2h-17A1.5 1.5 0 0 0 2 3.5v17A1.5 1.5 0 0 0 3.5 22h17a1.5 1.5 0 0 0 1.5-1.5v-17A1.5 1.5 0 0 0 20.5 2zM8 19H5v-9h3v9zM6.5 8.3a1.8 1.8 0 1 1 0-3.5 1.8 1.8 0 0 1 0 3.5zM19 19h-3v-4.7c0-1.1 0-2.5-1.5-2.5S13 13 13 14.2V19h-3v-9h2.9v1.3a3.1 3.1 0 0 1 2.8-1.5c3 0 3.5 2 3.5 4.5V19z"
          ></path>
        </svg>
      </a>
      <a
        href={`mailto:${socials.email}`}
        aria-label="Email"
        class="w-9 h-9 rounded-lg border border-lab-border flex items-center justify-center text-gray-500 hover:text-neon-cyan hover:border-neon-cyan transition-all"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path
            d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
          ></path>
          <polyline points="22,6 12,13 2,6"></polyline>
        </svg>
      </a>
    </div>
    <p class="text-[10px] text-gray-600 mt-6 font-mono">
      © {year}
      {site.name}<br />Built with Astro, Alpine.js & Tailwind
    </p>
  </div>
</aside>

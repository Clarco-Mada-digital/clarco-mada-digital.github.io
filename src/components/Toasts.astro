---
// Pile de notifications (toasts), pilotée par portfolioApp (toasts[], toast()).
---

<div
  class="fixed bottom-6 left-1/2 -translate-x-1/2 z-[70] flex flex-col items-center gap-2 w-[calc(100%-2rem)] max-w-sm pointer-events-none"
>
  <template x-for="t in toasts" :key="t.id">
    <div
      x-transition:enter="transition ease-out duration-300"
      x-transition:enter-start="opacity-0 translate-y-3 scale-95"
      x-transition:enter-end="opacity-100 translate-y-0 scale-100"
      x-transition:leave="transition ease-in duration-200"
      x-transition:leave-start="opacity-100 translate-y-0"
      x-transition:leave-end="opacity-0 translate-y-2"
      @click="removeToast(t.id)"
      class="pointer-events-auto w-full flex items-center gap-3 px-4 py-3 rounded-xl border bg-lab-card/95 backdrop-blur-md shadow-xl cursor-pointer"
      :class="{
        'border-neon-green/50': t.type === 'success',
        'border-red-400/50': t.type === 'error',
        'border-neon-cyan/50': t.type === 'info',
      }"
    >
      <span
        class="shrink-0 w-6 h-6 rounded-full flex items-center justify-center"
        :class="{
          'bg-neon-green/15 text-neon-green': t.type === 'success',
          'bg-red-400/15 text-red-400': t.type === 'error',
          'bg-neon-cyan/15 text-neon-cyan': t.type === 'info',
        }"
      >
        <svg x-show="t.type === 'success'" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"></path></svg>
        <svg x-show="t.type === 'error'" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M18 6 6 18M6 6l12 12"></path></svg>
        <svg x-show="t.type === 'info'" class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle></svg>
      </span>
      <span class="text-sm text-gray-200 flex-1" x-text="t.msg"></span>
    </div>
  </template>
</div>

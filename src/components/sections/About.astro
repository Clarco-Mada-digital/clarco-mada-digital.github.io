---
import { content } from "../../lib/content";
const { about } = content;
---

<section
  x-show="activeView === 'about'"
  x-transition:enter="transition ease-out duration-500"
  x-transition:enter-start="opacity-0 translate-y-4"
  x-transition:enter-end="opacity-100 translate-y-0"
  class="max-w-4xl"
  style="display: none"
>
  <h2 class="text-3xl sm:text-4xl font-bold text-white mb-2">// À propos</h2>
  <p class="text-gray-500 mb-10 font-mono text-sm">getPersonalInfo()</p>

  <div class="space-y-6 text-gray-400 leading-relaxed text-base sm:text-lg reveal">
    {about.paragraphs.map((p) => <p set:html={p} />)}
  </div>

  <div class="grid md:grid-cols-2 gap-6 mt-12">
    <div class="reveal bg-lab-card border border-lab-border rounded-xl p-6">
      <h3 class="text-white font-bold mb-4 flex items-center gap-2">
        <span class="text-neon-cyan">⚡</span> Ce que je fais
      </h3>
      <ul class="space-y-2 text-gray-400 text-sm">
        {
          about.doing.map((item) => (
            <li class="flex gap-2">
              <span class="text-neon-green">→</span> {item}
            </li>
          ))
        }
      </ul>
    </div>
    <div
      class="reveal bg-lab-card border border-lab-border rounded-xl p-6"
      style="transition-delay: 0.2s"
    >
      <h3 class="text-white font-bold mb-4 flex items-center gap-2">
        <span class="text-neon-purple">🎯</span> Ce que je recherche
      </h3>
      <ul class="space-y-2 text-gray-400 text-sm">
        {
          about.looking.map((item) => (
            <li class="flex gap-2">
              <span class="text-neon-purple">→</span> {item}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

---
import { content } from "../../lib/content";
const { contact } = content;
---

<section
  x-show="activeView === 'contact'"
  x-transition:enter="transition ease-out duration-500"
  x-transition:enter-start="opacity-0 translate-y-4"
  x-transition:enter-end="opacity-100 translate-y-0"
  class="max-w-4xl"
  style="display: none"
>
  <h2 class="text-3xl sm:text-4xl font-bold text-white mb-2">// Contact</h2>
  <p class="text-gray-500 mb-10 font-mono text-sm">initiateContact()</p>

  <div class="grid md:grid-cols-2 gap-8">
    <!-- Info -->
    <div class="reveal">
      <h3 class="text-2xl font-bold text-white mb-4">Travaillons ensemble !</h3>
      <p class="text-gray-400 mb-8 leading-relaxed">{contact.intro}</p>

      <div class="space-y-4">
        <a
          href={`mailto:${contact.email}`}
          class="flex items-center gap-4 p-4 bg-lab-card border border-lab-border rounded-xl card-hover"
        >
          <div
            class="w-10 h-10 rounded-lg bg-neon-cyan/10 flex items-center justify-center shrink-0"
          >
            <svg
              class="w-5 h-5 text-neon-cyan"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path
                d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
              ></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
          </div>
          <div class="min-w-0">
            <div class="text-xs text-gray-500 uppercase tracking-wider">
              Email
            </div>
            <span
              class="block text-white hover:text-neon-cyan transition-colors break-all text-sm sm:text-base"
              >{contact.email}</span
            >
          </div>
        </a>

        <div
          class="flex items-center gap-4 p-4 bg-lab-card border border-lab-border rounded-xl card-hover"
        >
          <div
            class="w-10 h-10 rounded-lg bg-neon-purple/10 flex items-center justify-center shrink-0"
          >
            <svg
              class="w-5 h-5 text-neon-purple"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
          </div>
          <div>
            <div class="text-xs text-gray-500 uppercase tracking-wider">
              Localisation
            </div>
            <div class="text-white">{contact.location}</div>
          </div>
        </div>

        <div
          class="flex items-center gap-4 p-4 bg-lab-card border border-lab-border rounded-xl card-hover"
        >
          <div
            class="w-10 h-10 rounded-lg bg-neon-green/10 flex items-center justify-center shrink-0"
          >
            <svg
              class="w-5 h-5 text-neon-green"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
          </div>
          <div>
            <div class="text-xs text-gray-500 uppercase tracking-wider">
              Statut
            </div>
            <div class="text-white flex items-center gap-2">
              <span class="w-2 h-2 bg-neon-green rounded-full animate-pulse"
              ></span>
              {contact.status}
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Formulaire -->
    <div
      class="reveal bg-lab-card border border-lab-border rounded-2xl p-6"
      style="transition-delay: 0.2s"
    >
      <!-- État de succès : remplace le formulaire -->
      <div
        x-show="formSent"
        x-cloak
        x-transition:enter="transition ease-out duration-400"
        x-transition:enter-start="opacity-0 scale-95"
        x-transition:enter-end="opacity-100 scale-100"
        class="text-center py-8"
        style="display:none"
      >
        <div
          class="w-16 h-16 mx-auto rounded-full bg-neon-green/10 border border-neon-green/40 flex items-center justify-center mb-5"
        >
          <svg
            class="w-8 h-8 text-neon-green"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            viewBox="0 0 24 24"
          >
            <path d="M20 6 9 17l-5-5"></path>
          </svg>
        </div>
        <h3 class="text-xl font-bold text-white mb-2">Message envoyé !</h3>
        <p class="text-gray-400 text-sm mb-6 leading-relaxed">
          Merci de m'avoir écrit 🙌<br />Je te réponds dans les plus brefs délais.
        </p>
        <button
          @click="resetContactForm()"
          class="px-5 py-2.5 border border-lab-border text-gray-300 text-sm font-bold rounded-lg hover:border-neon-cyan hover:text-neon-cyan transition-all"
        >
          Envoyer un autre message
        </button>
      </div>

      <form @submit.prevent="submitForm()" x-show="!formSent">
        <!-- Honeypot anti-spam (caché aux humains) -->
        <input
          type="text"
          x-model="form.botcheck"
          name="botcheck"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
          class="hidden"
        />
        <div class="space-y-4">
          <div>
            <label class="text-xs text-gray-500 font-mono mb-1.5 block">Nom</label
            >
            <input
              type="text"
              x-model="form.name"
              required
              class="w-full bg-lab-dark border border-lab-border rounded-lg px-4 py-2.5 text-white text-sm focus:outline-none focus:border-neon-cyan transition-colors"
              placeholder="Jean Dupont"
            />
          </div>
          <div>
            <label class="text-xs text-gray-500 font-mono mb-1.5 block"
              >Email</label
            >
            <input
              type="email"
              x-model="form.email"
              required
              class="w-full bg-lab-dark border border-lab-border rounded-lg px-4 py-2.5 text-white text-sm focus:outline-none focus:border-neon-cyan transition-colors"
              placeholder="jean@entreprise.com"
            />
          </div>
          <div>
            <label class="text-xs text-gray-500 font-mono mb-1.5 block"
              >Message</label
            >
            <textarea
              x-model="form.message"
              required
              rows="4"
              class="w-full bg-lab-dark border border-lab-border rounded-lg px-4 py-2.5 text-white text-sm focus:outline-none focus:border-neon-cyan transition-colors resize-none"
              placeholder="Parlez-moi de votre projet..."></textarea>
          </div>
          <button
            type="submit"
            :disabled="formSending"
            class="w-full py-3 bg-gradient-to-r from-neon-cyan to-neon-purple text-lab-dark font-bold rounded-lg hover:opacity-90 transition-opacity flex items-center justify-center gap-2 disabled:opacity-60"
          >
            <span x-show="!formSending">Envoyer le message</span>
            <span x-show="formSending" style="display: none" class="flex items-center gap-2">
              <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 0 1 8-8V0C5.4 0 0 5.4 0 12h4z"></path>
              </svg>
              Envoi…
            </span>
          </button>
          <p
            x-show="formError"
            style="display:none"
            class="text-xs text-red-400 text-center"
            x-text="formError"
          >
          </p>
        </div>
      </form>
    </div>
  </div>
</section>

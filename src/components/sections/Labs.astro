---
import { content } from "../../lib/content";
import { buildLabSrcdoc, hasDemo } from "../../lib/labs";
const { labs } = content;

// Métadonnées d'affichage par statut (badge + couleur néon).
const STATUS: Record<string, { label: string; cls: string }> = {
  done: { label: "✅ Terminé", cls: "text-neon-green border-neon-green/30 bg-neon-green/10" },
  wip: { label: "🧪 En cours", cls: "text-yellow-300 border-yellow-300/30 bg-yellow-300/10" },
  idea: { label: "💡 Idée", cls: "text-neon-purple border-neon-purple/30 bg-neon-purple/10" },
};
---

<section
  x-show="activeView === 'labs'"
  x-transition:enter="transition ease-out duration-500"
  x-transition:enter-start="opacity-0 translate-y-4"
  x-transition:enter-end="opacity-100 translate-y-0"
  class="max-w-6xl"
  style="display: none"
>
  <h2 class="text-3xl sm:text-4xl font-bold text-white mb-2">// Labs</h2>
  <p class="text-gray-500 mb-3 font-mono text-sm">runExperiments()</p>
  <p class="text-gray-400 mb-10 max-w-2xl leading-relaxed">
    Mon bac à sable : prototypes, tests d'API, mini-projets et idées en vrac.
    Chaque démo tourne <span class="text-neon-cyan">en vrai</span>, directement ci-dessous. 🧪
  </p>

  {
    labs.length === 0 && (
      <p class="text-gray-500 font-mono text-sm">
        Aucune expérimentation pour le moment. À venir…
      </p>
    )
  }

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
    {
      labs.map((lab, index) => {
        const meta = STATUS[lab.status] ?? STATUS.idea;
        const demo = hasDemo(lab);
        return (
          <div
            class="reveal group relative flex flex-col bg-lab-card border border-lab-border rounded-xl overflow-hidden card-hover"
            style={`transition-delay: ${index * 0.08}s`}
          >
            {/* Aperçu live (iframe sandboxé) ou bloc emoji */}
            {demo ? (
              <div class="relative h-44 bg-lab-dark border-b border-lab-border overflow-hidden">
                <iframe
                  title={`Démo : ${lab.title}`}
                  sandbox="allow-scripts"
                  loading="lazy"
                  srcdoc={buildLabSrcdoc(lab.demo)}
                  class="w-full h-full block"
                />
                <button
                  type="button"
                  @click={`openLab(${lab.id})`}
                  aria-label="Agrandir la démo"
                  class="absolute top-2 right-2 px-2 py-1 rounded-md bg-lab-dark/80 backdrop-blur-sm border border-lab-border text-[10px] font-mono text-neon-cyan hover:border-neon-cyan transition-colors opacity-0 group-hover:opacity-100 focus:opacity-100"
                >
                  ⛶ Agrandir
                </button>
              </div>
            ) : (
              <div class="h-44 flex items-center justify-center bg-lab-dark border-b border-lab-border">
                <span class="text-5xl">{lab.emoji || "🔬"}</span>
              </div>
            )}

            {/* Contenu */}
            <div class="flex flex-col flex-1 p-5">
              <div class="flex items-start justify-between gap-2 mb-2">
                <h3 class="text-white font-bold text-lg leading-tight">
                  <span class="mr-1">{lab.emoji}</span>
                  {lab.title}
                </h3>
                <span
                  class={`shrink-0 px-2 py-0.5 rounded-md text-[10px] font-mono border ${meta.cls}`}
                >
                  {meta.label}
                </span>
              </div>
              <p class="text-gray-500 text-sm leading-relaxed mb-4 flex-1">
                {lab.tagline}
              </p>
              <div class="flex flex-wrap gap-1.5 mb-4">
                {lab.tags.map((tag) => (
                  <span class="text-[10px] font-mono px-2 py-0.5 bg-lab-dark rounded text-gray-500 border border-lab-border">
                    {tag}
                  </span>
                ))}
              </div>
              <div class="flex gap-2 mt-auto">
                {demo && (
                  <button
                    type="button"
                    @click={`openLab(${lab.id})`}
                    class="flex-1 py-2 rounded-lg bg-lab-dark border border-lab-border text-xs font-mono text-neon-cyan hover:border-neon-cyan transition-colors flex items-center justify-center gap-1.5"
                  >
                    ▶ Voir le code
                  </button>
                )}
                {lab.url && (
                  <a
                    href={lab.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex-1 py-2 rounded-lg bg-lab-dark border border-lab-border text-xs font-mono text-gray-400 hover:text-neon-cyan hover:border-neon-cyan transition-colors flex items-center justify-center gap-1.5"
                  >
                    Lien ↗
                  </a>
                )}
              </div>
            </div>
          </div>
        );
      })
    }
  </div>
</section>

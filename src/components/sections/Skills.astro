---
import { content } from "../../lib/content";
const { skills, tools } = content;
---

<section
  x-show="activeView === 'skills'"
  x-transition:enter="transition ease-out duration-500"
  x-transition:enter-start="opacity-0 translate-y-4"
  x-transition:enter-end="opacity-100 translate-y-0"
  class="max-w-5xl"
  style="display: none"
>
  <h2 class="text-4xl font-bold text-white mb-2">// Compétences</h2>
  <p class="text-gray-500 mb-10 font-mono text-sm">getTechStack()</p>

  <div class="grid md:grid-cols-3 gap-6">
    {
      skills.map((category, index) => (
        <div
          class="reveal bg-lab-card border border-lab-border rounded-xl p-6 card-hover"
          style={`transition-delay: ${index * 0.1}s`}
        >
          <div class="flex items-center gap-3 mb-5">
            <span class="text-2xl">{category.icon}</span>
            <h3 class="text-white font-bold text-lg">{category.name}</h3>
          </div>
          <div class="flex flex-wrap gap-2">
            {category.items.map((tech) => (
              <span class="px-3 py-1.5 bg-lab-dark border border-lab-border rounded-md text-xs font-mono text-gray-400 hover:text-neon-cyan hover:border-neon-cyan/50 transition-colors cursor-default">
                {tech}
              </span>
            ))}
          </div>
        </div>
      ))
    }
  </div>

  <!-- Outils & Workflow -->
  <div class="reveal mt-8 bg-lab-card border border-lab-border rounded-xl p-6">
    <h3 class="text-white font-bold mb-4">🛠️ Outils & Workflow</h3>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm text-gray-400">
      {
        tools.map((tool) => (
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 bg-neon-cyan rounded-full" />
            {tool}
          </div>
        ))
      }
    </div>
  </div>
</section>

---
// Polices auto-hébergées (woff2 dans le build, aucune requête externe).
// Plusieurs familles : le visiteur peut changer de combinaison (le navigateur
// ne télécharge que la police réellement utilisée).
// Paires de polices proposées dans le panneau « Personnaliser ».
// (unicode-range fait que le navigateur ne télécharge que le sous-ensemble
// latin de la police active — les autres subsets ne transitent jamais.)
import "@fontsource-variable/space-grotesk/index.css";
import "@fontsource/space-mono/400.css";
import "@fontsource/space-mono/700.css";
import "@fontsource-variable/sora/index.css";
import "@fontsource-variable/jetbrains-mono/index.css";
import "@fontsource-variable/inter/index.css";
import "@fontsource/chakra-petch/400.css";
import "@fontsource/chakra-petch/700.css";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/ibm-plex-mono/700.css";
import "@fontsource-variable/outfit/index.css";
import "@fontsource-variable/manrope/index.css";
import "@fontsource-variable/fira-code/index.css";
import "../styles/global.css";
import { content } from "../lib/content";
import { assetUrl } from "../lib/url";

interface Props {
  title?: string;
  description?: string;
  noIndex?: boolean;
  // Image de partage spécifique à la page (ex. couverture d'un article).
  image?: string;
  // "website" (défaut) ou "article" pour une page de blog.
  ogType?: string;
  // Date de publication (ISO) — ajoutée aux meta Open Graph d'un article.
  publishedTime?: string;
}

const {
  title = content.site.titleTag,
  description = content.site.description,
  noIndex = false,
  image,
  ogType = "website",
  publishedTime,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const site = Astro.site ?? new URL(Astro.url.origin);
const canonical = new URL(Astro.url.pathname, site);
// Image de partage : celle fournie par la page (couverture d'article…) sinon
// l'image générique du site. Toujours résolue en URL absolue (requis par OG).
const ogImage = image
  ? new URL(assetUrl(image, base), site).href
  : new URL(`${base}og-image.png`, site).href;

// Cloudflare Web Analytics : token public (env prioritaire, sinon admin).
// Chargé seulement en build de production pour ne pas polluer les stats en dev.
const cfToken =
  process.env.CF_ANALYTICS_TOKEN || content.analytics?.cloudflareToken || "";
const enableAnalytics = import.meta.env.PROD && Boolean(cfToken);

// Données structurées (SEO) : décrit la personne pour les moteurs de recherche.
const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: content.site.name,
  jobTitle: content.site.role,
  url: site.href,
  image: ogImage,
  email: content.contact.email,
  sameAs: [content.socials.github, content.socials.linkedin].filter(Boolean),
};
// Échappe "<" pour éviter toute fermeture de balise script via le contenu.
const personLdJson = JSON.stringify(personLd).replace(/</g, "\\u003c");
---

<!doctype html>
<html lang="fr" class="dark scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {/* Content-Security-Policy (defense-in-depth). Alpine impose unsafe-inline
        et unsafe-eval ; on verrouille en revanche object/base-uri et on limite
        les origines connect/img/frame autorisées. */}
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://static.cloudflareinsights.com https://cdn.jsdelivr.net https://unpkg.com https://cdnjs.cloudflare.com https://code.jquery.com https://cdn.tailwindcss.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://unpkg.com https://fonts.googleapis.com; img-src 'self' data: blob: https:; font-src 'self' data: https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://fonts.gstatic.com; connect-src 'self' https:; frame-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self' https://api.web3forms.com;"
    />
    <!-- Applique thème clair/sombre + préférences (police, palette) AVANT le
         rendu pour éviter tout flash. -->
    <script is:inline>
      (function () {
        var root = document.documentElement;
        try {
          var t = localStorage.getItem("theme");
          if (!t) {
            t = window.matchMedia("(prefers-color-scheme: light)").matches
              ? "light"
              : "dark";
          }
          root.classList.toggle("light", t === "light");

          var fs = localStorage.getItem("ui-font-sans");
          var fm = localStorage.getItem("ui-font-mono");
          if (fs) root.style.setProperty("--font-sans", fs);
          if (fm) root.style.setProperty("--font-mono", fm);

          var neon = localStorage.getItem("ui-neon");
          if (neon) {
            var n = JSON.parse(neon);
            root.style.setProperty("--neon-cyan", n[0]);
            root.style.setProperty("--neon-purple", n[1]);
            root.style.setProperty("--neon-green", n[2]);
          }
        } catch (e) {}
      })();
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={content.site.name} />
    <link rel="canonical" href={canonical} />
    {
      noIndex ? (
        <meta name="robots" content="noindex, nofollow" />
      ) : (
        <meta name="robots" content="index, follow" />
      )
    }

    <!-- Open Graph / réseaux sociaux -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={content.site.name} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    {
      ogType === "article" && publishedTime && (
        <>
          <meta property="article:published_time" content={publishedTime} />
          <meta property="article:author" content={content.site.name} />
        </>
      )
    }
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {
      !noIndex && (
        <script type="application/ld+json" set:html={personLdJson} />
      )
    }
    {/* Données structurées additionnelles propres à la page (ex. BlogPosting). */}
    <slot name="head" />

    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="theme-color" content="#070a0f" />

    <!-- PWA : installable + hors-ligne -->
    <link rel="manifest" href={`${base}manifest.webmanifest`} />
    <link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Bryan Clark" />
  </head>

  <body
    class="font-sans text-gray-300 antialiased bg-grid selection:bg-neon-cyan selection:text-lab-dark"
  >
    <!-- Écran de chargement (ADN terminal du portfolio) -->
    <div id="preloader" aria-hidden="true">
      <div class="pl-box">
        <div class="pl-logo">{content.site.initials}</div>
        <div class="pl-line">
          <span class="pl-prompt">$</span>initialisation du portfolio<span
            class="pl-cursor">▋</span
          >
        </div>
        <div class="pl-bar"><i></i></div>
      </div>
    </div>
    <script is:inline>
      (function () {
        var done = function () {
          document.documentElement.classList.add("pl-done");
        };
        // Masque dès que tout est chargé (avec un minimum visuel court),
        // et un filet de sécurité si l'évènement load tarde.
        if (document.readyState === "complete") {
          setTimeout(done, 300);
        } else {
          window.addEventListener("load", function () {
            setTimeout(done, 350);
          });
        }
        setTimeout(done, 2500);
      })();
    </script>

    <!-- Canvas pour les particules de fond -->
    <canvas id="particle-canvas"></canvas>

    <!-- Curseur personnalisé -->
    <div class="cursor-dot"></div>
    <div class="cursor-outline"></div>

    <slot />

    <script>
      import "../scripts/effects";
    </script>

    {/* Cloudflare Web Analytics (sans cookies, RGPD-friendly) */}
    {
      enableAnalytics && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={`{"token": "${cfToken}"}`}
        />
      )
    }

    {/* Enregistrement du service worker (PWA) — production uniquement */}
    <script
      is:inline
      define:vars={{ swPath: `${base}sw.js`, swScope: base, enableSw: import.meta.env.PROD }}
    >
      if (enableSw && "serviceWorker" in navigator) {
        window.addEventListener("load", function () {
          navigator.serviceWorker
            .register(swPath, { scope: swScope })
            .catch(function () {});
        });
      }
    </script>
  </body>
</html>

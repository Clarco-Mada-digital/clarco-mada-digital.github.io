---
import "../styles/global.css";
import { content } from "../lib/content";

interface Props {
  title?: string;
  description?: string;
  noIndex?: boolean;
}

const {
  title = content.site.titleTag,
  description = content.site.description,
  noIndex = false,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const site = Astro.site ?? new URL(Astro.url.origin);
const canonical = new URL(Astro.url.pathname, site);
const ogImage = new URL(`${base}og-image.png`, site).href;

// Données structurées (SEO) : décrit la personne pour les moteurs de recherche.
const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: content.site.name,
  jobTitle: content.site.role,
  url: site.href,
  image: ogImage,
  email: content.contact.email,
  sameAs: [content.socials.github, content.socials.linkedin].filter(Boolean),
};
// Échappe "<" pour éviter toute fermeture de balise script via le contenu.
const personLdJson = JSON.stringify(personLd).replace(/</g, "\\u003c");
---

<!doctype html>
<html lang="fr" class="dark scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Applique le thème AVANT le rendu pour éviter tout flash. -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem("theme");
          if (!t) {
            t = window.matchMedia("(prefers-color-scheme: light)").matches
              ? "light"
              : "dark";
          }
          document.documentElement.classList.toggle("light", t === "light");
        } catch (e) {}
      })();
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={content.site.name} />
    <link rel="canonical" href={canonical} />
    {
      noIndex ? (
        <meta name="robots" content="noindex, nofollow" />
      ) : (
        <meta name="robots" content="index, follow" />
      )
    }

    <!-- Open Graph / réseaux sociaux -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={content.site.name} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {
      !noIndex && (
        <script type="application/ld+json" set:html={personLdJson} />
      )
    }

    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="theme-color" content="#070a0f" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body
    class="font-sans text-gray-300 antialiased bg-grid selection:bg-neon-cyan selection:text-lab-dark"
  >
    <!-- Canvas pour les particules de fond -->
    <canvas id="particle-canvas"></canvas>

    <!-- Curseur personnalisé -->
    <div class="cursor-dot"></div>
    <div class="cursor-outline"></div>

    <slot />

    <script>
      import "../scripts/effects";
    </script>
  </body>
</html>

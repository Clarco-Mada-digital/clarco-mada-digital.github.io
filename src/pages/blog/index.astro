---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import { content } from "../../lib/content";

const { site } = content;
const base = import.meta.env.BASE_URL;

// Articles publiés (les brouillons sont masqués en production), triés du + récent.
const posts = (await getCollection("blog"))
  .filter((p) => import.meta.env.DEV || !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" });

const readingTime = (body: string) =>
  Math.max(1, Math.round(body.split(/\s+/).length / 200));
---

<Base
  title={`Blog // ${site.name}`}
  description={`Articles et notes techniques de ${site.name}.`}
>
  <!-- Barre supérieure -->
  <header
    class="sticky top-0 z-30 bg-lab-dark/90 backdrop-blur-md border-b border-lab-border"
  >
    <div class="max-w-4xl mx-auto px-5 sm:px-8 py-3 flex items-center justify-between">
      <a href={base} class="flex items-center gap-2.5 group">
        <div
          class="w-9 h-9 rounded-lg bg-gradient-to-br from-neon-cyan to-neon-purple flex items-center justify-center text-lab-dark font-extrabold"
        >
          {site.initials}
        </div>
        <span class="font-mono text-sm text-white group-hover:text-neon-cyan transition-colors">
          {site.handle}
        </span>
      </a>
      <a
        href={base}
        class="text-sm font-mono text-gray-400 hover:text-neon-cyan transition-colors flex items-center gap-1.5"
      >
        ← Portfolio
      </a>
    </div>
  </header>

  <main class="max-w-4xl mx-auto px-5 sm:px-8 py-12 min-h-[70vh]">
    <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">// Blog</h1>
    <p class="text-gray-500 mb-10 font-mono text-sm">writeThoughts()</p>

    {
      posts.length === 0 && (
        <p class="text-gray-500 font-mono text-sm">
          Aucun article pour le moment. Reviens bientôt !
        </p>
      )
    }

    <div class="space-y-5">
      {
        posts.map((post) => (
          <a
            href={`${base}blog/${post.slug}`}
            class="block bg-lab-card border border-lab-border rounded-xl p-6 card-hover group"
          >
            <div class="flex items-center gap-3 text-xs font-mono text-gray-500 mb-2">
              <time datetime={post.data.date.toISOString()}>{fmt(post.data.date)}</time>
              <span>·</span>
              <span>{readingTime(post.body)} min de lecture</span>
              {post.data.draft && (
                <span class="px-1.5 py-0.5 rounded bg-yellow-300/10 border border-yellow-300/30 text-yellow-300">
                  brouillon
                </span>
              )}
            </div>
            <h2 class="text-xl font-bold text-white mb-2 group-hover:text-neon-cyan transition-colors">
              {post.data.title}
            </h2>
            <p class="text-gray-400 text-sm leading-relaxed mb-4">
              {post.data.description}
            </p>
            <div class="flex flex-wrap gap-1.5">
              {post.data.tags.map((tag) => (
                <span class="text-[10px] font-mono px-2 py-0.5 bg-lab-dark rounded text-gray-500 border border-lab-border">
                  {tag}
                </span>
              ))}
            </div>
          </a>
        ))
      }
    </div>
  </main>
</Base>

---
import "katex/dist/katex.min.css"; // styles des maths dans l'aperçu d'article
import Base from "../layouts/Base.astro";
import { content } from "../lib/content";

const base = import.meta.env.BASE_URL;

// Classes réutilisées (rendues côté serveur dans les templates Alpine).
const input =
  "w-full bg-lab-dark border border-lab-border rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-neon-cyan transition-colors";
const label = "text-[11px] text-gray-500 font-mono uppercase tracking-wider mb-1 block";
const card = "bg-lab-card border border-lab-border rounded-xl p-5";
const miniBtn =
  "w-7 h-7 rounded-md border border-lab-border text-gray-400 hover:text-neon-cyan hover:border-neon-cyan transition-colors flex items-center justify-center text-xs";
const addBtn =
  "text-xs font-mono px-3 py-1.5 rounded-md border border-dashed border-lab-border text-gray-400 hover:text-neon-cyan hover:border-neon-cyan transition-colors";
---

<Base title="Admin // Bryan Clark" noIndex={true}>
  <div x-data="adminApp" x-cloak class="min-h-screen max-w-7xl mx-auto p-5 md:p-8">
    <!-- Garde-fou d'accès (soft) -->
    <div
      x-show="!unlocked"
      class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-lab-dark"
    >
      <form
        @submit.prevent="tryUnlock()"
        class="w-full max-w-sm bg-lab-card border border-lab-border rounded-2xl p-6 space-y-4"
      >
        <div class="flex items-center gap-3">
          <div
            class="w-10 h-10 rounded-lg bg-gradient-to-br from-neon-cyan to-neon-purple flex items-center justify-center text-lab-dark text-lg"
          >
            🔒
          </div>
          <div>
            <div class="text-white font-bold">Console privée</div>
            <div class="text-gray-500 text-xs font-mono">Accès réservé</div>
          </div>
        </div>
        <input
          type="password"
          x-model="gateInput"
          @input="gateError = false"
          placeholder="Phrase d'accès"
          autocomplete="current-password"
          class={input}
        />
        <p x-show="gateError" style="display:none" class="text-red-400 text-xs font-mono">
          Phrase incorrecte.
        </p>
        <button
          type="submit"
          class="w-full py-2.5 rounded-lg bg-neon-cyan text-lab-dark font-bold text-sm hover:bg-white transition-colors"
        >
          Déverrouiller
        </button>
      </form>
    </div>

    <!-- En-tête -->
    <header
      x-show="unlocked"
      class="sticky top-0 z-30 -mx-5 md:-mx-8 px-5 md:px-8 py-4 bg-lab-dark/85 backdrop-blur-md border-b border-lab-border mb-8"
    >
      <div class="flex flex-wrap items-center gap-3 justify-between">
        <div class="flex items-center gap-3">
          <div
            class="w-9 h-9 rounded-lg bg-gradient-to-br from-neon-cyan to-neon-purple flex items-center justify-center text-lab-dark font-extrabold"
          >
            ⚙
          </div>
          <div>
            <div class="text-white font-bold font-mono text-sm">Console Admin</div>
            <div class="text-[11px] font-mono flex items-center gap-1.5">
              <template x-if="apiAvailable">
                <span class="text-neon-green flex items-center gap-1.5">
                  <span class="w-1.5 h-1.5 bg-neon-green rounded-full animate-pulse"
                  ></span>
                  serveur local — sauvegarde fichier active
                </span>
              </template>
              <template x-if="!apiAvailable">
                <span class="text-yellow-500"
                  >hors-ligne — export/import uniquement</span
                >
              </template>
            </div>
          </div>
        </div>

        <div class="flex items-center gap-2">
          <a href={base} class={miniBtn + ' !w-auto px-3 gap-1'} title="Voir le site"
            >↗ Site</a
          >
          <label class={addBtn + ' cursor-pointer'}>
            Importer
            <input type="file" accept="application/json" class="hidden" @change="importJson($event)" />
          </label>
          <button @click="exportJson()" class={addBtn}>Exporter</button>
          <button
            @click="save()"
            :disabled="saving"
            class="text-xs font-bold px-4 py-2 rounded-md bg-neon-cyan text-lab-dark hover:bg-white transition-colors disabled:opacity-50"
          >
            <span x-show="!saving">💾 Sauvegarder</span>
            <span x-show="saving" style="display:none">Sauvegarde…</span>
          </button>
        </div>
      </div>

      <!-- Statut -->
      <div
        x-show="status"
        style="display:none"
        class="mt-3 text-xs font-mono px-3 py-2 rounded-md border"
        :class="statusType === 'success' ? 'text-neon-green border-neon-green/40 bg-neon-green/5' : statusType === 'error' ? 'text-red-400 border-red-400/40 bg-red-400/5' : 'text-neon-cyan border-neon-cyan/40 bg-neon-cyan/5'"
        x-text="status"
      >
      </div>
    </header>

    <!-- Chargement -->
    <div x-show="unlocked && loading" class="text-gray-500 font-mono text-sm">
      Chargement des données…
    </div>

    <div x-show="unlocked && !loading" style="display:none" class="flex flex-col md:flex-row gap-8">
      <!-- Onglets -->
      <nav class="md:w-44 flex md:flex-col gap-1 overflow-x-auto md:overflow-visible shrink-0">
        <template x-for="tab in tabs" :key="tab.id">
          <button
            @click="activeTab = tab.id"
            class="text-left whitespace-nowrap py-2 px-3 rounded-lg font-mono text-sm transition-colors"
            :class="activeTab === tab.id ? 'bg-lab-card text-neon-cyan' : 'text-gray-500 hover:text-white'"
            x-text="tab.label"
          >
          </button>
        </template>
      </nav>

      <!-- Panneaux -->
      <div class="flex-1 min-w-0 space-y-5">
        <!-- ====== IDENTITÉ ====== -->
        <section x-show="activeTab === 'site'" class:list={[card, 'space-y-4']}>
          <h2 class="text-white font-bold">Identité</h2>

          <!-- Photo de profil -->
          <div class="flex items-start gap-4">
            <div
              class="w-20 h-20 rounded-full overflow-hidden border-2 border-lab-border shrink-0 bg-lab-dark flex items-center justify-center"
            >
              <template x-if="data.site.photo">
                <img :src="asset(data.site.photo)" alt="" class="w-full h-full object-cover" />
              </template>
              <template x-if="!data.site.photo">
                <span class="text-[10px] text-gray-600 font-mono text-center">aucune<br />photo</span>
              </template>
            </div>
            <div class="flex-1">
              <label class={label}>Photo de profil (affichée sur le CV)</label>
              <input class={input} x-model="data.site.photo" placeholder="URL ou /profile/moi.jpg" />
              <div class="flex gap-2 mt-2">
                <label class={addBtn + ' cursor-pointer'}>
                  ⬆ Uploader une photo
                  <input type="file" accept="image/*" class="hidden" @change="uploadPhoto($event)" />
                </label>
                <button x-show="data.site.photo" class={miniBtn + ' !w-auto px-2'} @click="data.site.photo = ''">retirer</button>
              </div>
            </div>
          </div>

          <div class="grid sm:grid-cols-2 gap-4">
            <div><label class={label}>Nom complet</label><input class={input} x-model="data.site.name" /></div>
            <div><label class={label}>Handle (~/...)</label><input class={input} x-model="data.site.handle" /></div>
            <div><label class={label}>Initiale (logo)</label><input class={input} x-model="data.site.initials" /></div>
            <div><label class={label}>Rôle</label><input class={input} x-model="data.site.role" /></div>
          </div>
          <div><label class={label}>Titre de l'onglet (SEO)</label><input class={input} x-model="data.site.titleTag" /></div>
          <div><label class={label}>Description (SEO)</label><textarea rows="2" class={input} x-model="data.site.description"></textarea></div>
          <div class="grid sm:grid-cols-2 gap-4 items-end">
            <div><label class={label}>Libellé disponibilité</label><input class={input} x-model="data.site.availabilityLabel" /></div>
            <label class="flex items-center gap-2 text-sm text-gray-300 py-2">
              <input type="checkbox" x-model="data.site.available" class="accent-neon-cyan" /> Afficher « disponible »
            </label>
          </div>

          <!-- CV -->
          <div class="border-t border-lab-border pt-4">
            <label class={label}>CV (bouton « Télécharger mon CV »)</label>
            <div class="flex flex-wrap items-center gap-2">
              <input class={input + ' !flex-1 min-w-[200px]'} x-model="data.site.cvUrl" placeholder="URL ou /cv/mon-cv.pdf — vide = bouton masqué" />
              <label class={addBtn + ' cursor-pointer'}>
                ⬆ Uploader (PDF)
                <input type="file" accept="application/pdf,image/*" class="hidden" @change="uploadCv($event)" />
              </label>
              <template x-if="data.site.cvUrl">
                <a :href="asset(data.site.cvUrl)" target="_blank" rel="noopener" class={addBtn}>Voir</a>
              </template>
              <button x-show="data.site.cvUrl" class={miniBtn + ' !w-auto px-2'} @click="data.site.cvUrl = ''">retirer</button>
            </div>
            <p class="text-[11px] text-gray-600 mt-2 font-mono">Le PDF déposé est enregistré dans <span class="text-neon-cyan">public/cv/</span>.</p>
          </div>
        </section>

        <!-- ====== HERO ====== -->
        <section x-show="activeTab === 'hero'" style="display:none" class:list={[card, 'space-y-4']}>
          <h2 class="text-white font-bold">Section Hero</h2>
          <div><label class={label}>Accroche (effet machine à écrire)</label><textarea rows="2" class={input} x-model="data.hero.tagline"></textarea></div>
          <h3 class="text-gray-400 text-sm font-mono pt-2">Bloc code « developer.js »</h3>
          <div class="grid sm:grid-cols-2 gap-4">
            <div><label class={label}>name</label><input class={input} x-model="data.hero.code.name" /></div>
            <div><label class={label}>role</label><input class={input} x-model="data.hero.code.role" /></div>
            <div><label class={label}>location</label><input class={input} x-model="data.hero.code.location" /></div>
            <div><label class={label}>passions</label><input class={input} x-model="data.hero.code.passions" /></div>
          </div>
          <div>
            <label class={label}>stack</label>
            <div class="space-y-2">
              <template x-for="(_, i) in data.hero.code.stack" :key="i">
                <div class="flex gap-2">
                  <input class={input} x-model="data.hero.code.stack[i]" />
                  <button class={miniBtn} @click="remove(data.hero.code.stack, i)">✕</button>
                </div>
              </template>
            </div>
            <button class={addBtn + ' mt-2'} @click="addString(data.hero.code.stack)">+ techno</button>
          </div>
        </section>

        <!-- ====== STATS ====== -->
        <section x-show="activeTab === 'stats'" style="display:none" class:list={[card, 'space-y-4']}>
          <div class="flex items-center justify-between">
            <h2 class="text-white font-bold">Statistiques</h2>
            <button class={addBtn} @click="addStat()">+ Stat</button>
          </div>
          <template x-for="(stat, i) in data.stats" :key="i">
            <div class="flex flex-wrap items-end gap-3 border border-lab-border rounded-lg p-3">
              <div class="w-20"><label class={label}>Valeur</label><input class={input} x-model="stat.value" /></div>
              <div class="flex-1 min-w-[140px]"><label class={label}>Libellé</label><input class={input} x-model="stat.label" /></div>
              <div class="w-36">
                <label class={label}>Couleur</label>
                <select class={input} x-model="stat.color">
                  <option value="neon-cyan">cyan</option>
                  <option value="neon-purple">purple</option>
                  <option value="neon-green">green</option>
                  <option value="white">blanc</option>
                </select>
              </div>
              <div class="flex gap-1">
                <button class={miniBtn} @click="move(data.stats, i, -1)">↑</button>
                <button class={miniBtn} @click="move(data.stats, i, 1)">↓</button>
                <button class={miniBtn} @click="remove(data.stats, i)">✕</button>
              </div>
            </div>
          </template>
        </section>

        <!-- ====== À PROPOS ====== -->
        <section x-show="activeTab === 'about'" style="display:none" class:list={[card, 'space-y-5']}>
          <h2 class="text-white font-bold">À propos</h2>
          <div>
            <label class={label}>Paragraphes</label>
            <div class="space-y-2">
              <template x-for="(_, i) in data.about.paragraphs" :key="i">
                <div class="flex gap-2">
                  <textarea rows="3" class={input} x-model="data.about.paragraphs[i]"></textarea>
                  <button class={miniBtn} @click="remove(data.about.paragraphs, i)">✕</button>
                </div>
              </template>
            </div>
            <button class={addBtn + ' mt-2'} @click="addString(data.about.paragraphs)">+ paragraphe</button>
          </div>
          <div class="grid sm:grid-cols-2 gap-6">
            <div>
              <label class={label}>Ce que je fais</label>
              <div class="space-y-2">
                <template x-for="(_, i) in data.about.doing" :key="i">
                  <div class="flex gap-2">
                    <input class={input} x-model="data.about.doing[i]" />
                    <button class={miniBtn} @click="remove(data.about.doing, i)">✕</button>
                  </div>
                </template>
              </div>
              <button class={addBtn + ' mt-2'} @click="addString(data.about.doing)">+ ligne</button>
            </div>
            <div>
              <label class={label}>Ce que je recherche</label>
              <div class="space-y-2">
                <template x-for="(_, i) in data.about.looking" :key="i">
                  <div class="flex gap-2">
                    <input class={input} x-model="data.about.looking[i]" />
                    <button class={miniBtn} @click="remove(data.about.looking, i)">✕</button>
                  </div>
                </template>
              </div>
              <button class={addBtn + ' mt-2'} @click="addString(data.about.looking)">+ ligne</button>
            </div>
          </div>
        </section>

        <!-- ====== COMPÉTENCES ====== -->
        <section x-show="activeTab === 'skills'" style="display:none" class="space-y-5">
          <div class:list={[card, 'space-y-4']}>
            <div class="flex items-center justify-between">
              <h2 class="text-white font-bold">Catégories de compétences</h2>
              <button class={addBtn} @click="addSkillCategory()">+ Catégorie</button>
            </div>
            <template x-for="(cat, ci) in data.skills" :key="ci">
              <div class="border border-lab-border rounded-lg p-4 space-y-3">
                <div class="flex gap-3 items-end">
                  <div class="w-16"><label class={label}>Icône</label><input class={input} x-model="cat.icon" /></div>
                  <div class="flex-1"><label class={label}>Nom</label><input class={input} x-model="cat.name" /></div>
                  <div class="flex gap-1">
                    <button class={miniBtn} @click="move(data.skills, ci, -1)">↑</button>
                    <button class={miniBtn} @click="move(data.skills, ci, 1)">↓</button>
                    <button class={miniBtn} @click="remove(data.skills, ci)">✕</button>
                  </div>
                </div>
                <div>
                  <label class={label}>Technologies</label>
                  <div class="flex flex-wrap gap-2">
                    <template x-for="(_, ti) in cat.items" :key="ti">
                      <div class="flex gap-1 items-center">
                        <input class={input + ' !w-32'} x-model="cat.items[ti]" />
                        <button class={miniBtn} @click="remove(cat.items, ti)">✕</button>
                      </div>
                    </template>
                  </div>
                  <button class={addBtn + ' mt-2'} @click="addString(cat.items)">+ techno</button>
                </div>
              </div>
            </template>
          </div>

          <div class:list={[card, 'space-y-3']}>
            <label class={label}>Outils & Workflow</label>
            <div class="flex flex-wrap gap-2">
              <template x-for="(_, i) in data.tools" :key="i">
                <div class="flex gap-1 items-center">
                  <input class={input + ' !w-40'} x-model="data.tools[i]" />
                  <button class={miniBtn} @click="remove(data.tools, i)">✕</button>
                </div>
              </template>
            </div>
            <button class={addBtn} @click="addString(data.tools)">+ outil</button>
          </div>
        </section>

        <!-- ====== PROJETS ====== -->
        <section x-show="activeTab === 'projects'" style="display:none" class="space-y-5">
          <div class="flex items-center justify-between">
            <h2 class="text-white font-bold">Projets <span class="text-gray-600 text-sm font-mono" x-text="'(' + data.projects.length + ')'"></span></h2>
            <button class={addBtn} @click="addProject()">+ Nouveau projet</button>
          </div>
          <input
            type="search"
            x-model="projectQuery"
            placeholder="Rechercher un projet par nom…"
            class={input + ' !max-w-sm'}
          />
          <template x-for="(project, pi) in data.projects" :key="project.id">
            <div class:list={[card, 'space-y-0']} x-show="matches(project.name, projectQuery)">
              <!-- En-tête (toujours visible) : cliquer pour déplier/replier -->
              <div class="flex items-start gap-3 cursor-pointer select-none" @click="toggleProject(project.id)">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 flex-wrap">
                    <span class="text-gray-600 font-mono text-xs" x-text="isProjectOpen(project.id) ? '▾' : '▸'"></span>
                    <span class="text-white font-bold truncate" x-text="project.name || 'Sans titre'"></span>
                    <span class="text-gray-600 font-mono text-xs" x-text="project.year"></span>
                    <span
                      class="text-[10px] font-mono px-1.5 py-0.5 rounded"
                      :class="project.category === 'pro' ? 'bg-neon-purple/20 text-neon-purple' : 'bg-neon-cyan/20 text-neon-cyan'"
                      x-text="project.category === 'pro' ? ('Pro' + (project.company ? ' · ' + project.company : '')) : 'Perso'"
                    ></span>
                    <span x-show="project.featured" class="text-[10px] font-mono px-1.5 py-0.5 rounded bg-yellow-500/20 text-yellow-400">★</span>
                    <span x-show="project.includeInCv === false" class="text-[10px] font-mono px-1.5 py-0.5 rounded bg-lab-dark text-gray-500">hors CV</span>
                  </div>
                  <p x-show="!isProjectOpen(project.id)" class="text-gray-500 text-xs mt-1 truncate" x-text="project.shortDesc"></p>
                </div>
                <div class="flex gap-1 shrink-0" @click.stop>
                  <button class={miniBtn} @click="move(data.projects, pi, -1)">↑</button>
                  <button class={miniBtn} @click="move(data.projects, pi, 1)">↓</button>
                  <button class={miniBtn} @click="remove(data.projects, pi)">✕</button>
                </div>
              </div>

              <div x-show="isProjectOpen(project.id)" class="space-y-4 pt-4">
              <div class="grid sm:grid-cols-2 gap-4">
                <div><label class={label}>Nom</label><input class={input} x-model="project.name" /></div>
                <div><label class={label}>Année</label><input class={input} x-model="project.year" /></div>
              </div>

              <!-- Catégorie : perso ou pro (+ entreprise/statut si pro) -->
              <div class="border-t border-lab-border pt-4 grid sm:grid-cols-2 gap-4">
                <div>
                  <label class={label}>Catégorie</label>
                  <select class={input} x-model="project.category">
                    <option value="perso">Personnel</option>
                    <option value="pro">Professionnel</option>
                  </select>
                </div>
                <label class="flex items-center gap-2 text-sm text-gray-300 py-2 sm:pt-6">
                  <input type="checkbox" x-model="project.includeInCv" class="accent-neon-cyan" /> Inclure dans le CV généré
                </label>
                <template x-if="project.category === 'pro'">
                  <div><label class={label}>Entreprise / client</label><input class={input} x-model="project.company" placeholder="ex. MADA-Digital" /></div>
                </template>
                <template x-if="project.category === 'pro'">
                  <div>
                    <label class={label}>Statut</label>
                    <select class={input} x-model="project.employment">
                      <option value="salarie">Salarié</option>
                      <option value="freelance">Freelance</option>
                    </select>
                  </div>
                </template>
              </div>

              <div><label class={label}>Description courte</label><textarea rows="2" class={input} x-model="project.shortDesc"></textarea></div>
              <div><label class={label}>Description complète (modale)</label><textarea rows="3" class={input} x-model="project.fullDesc"></textarea></div>

              <div class="grid sm:grid-cols-2 gap-4">
                <div><label class={label}>Lien code (repo)</label><input class={input} x-model="project.repoUrl" placeholder="https://github.com/..." /></div>
                <div><label class={label}>Lien démo</label><input class={input} x-model="project.demoUrl" placeholder="https://..." /></div>
              </div>

              <!-- Images -->
              <div class="border-t border-lab-border pt-4 space-y-4">
                <!-- Couverture -->
                <div>
                  <label class={label}>Image de couverture</label>
                  <div class="flex items-start gap-3">
                    <div
                      class="w-24 h-16 rounded-md border border-lab-border shrink-0 bg-lab-dark overflow-hidden flex items-center justify-center"
                      :class="!project.cover && project.gradient"
                    >
                      <template x-if="project.cover">
                        <img :src="asset(project.cover)" alt="" class="w-full h-full object-cover" />
                      </template>
                      <template x-if="!project.cover">
                        <span class="text-[10px] text-gray-600 font-mono">aucune</span>
                      </template>
                    </div>
                    <div class="flex-1 space-y-2">
                      <input class={input} x-model="project.cover" placeholder="URL ou /projects/mon-image.jpg" />
                      <div class="flex gap-2">
                        <label class={addBtn + ' cursor-pointer'}>
                          ⬆ Uploader
                          <input type="file" accept="image/*" class="hidden" @change="uploadCover($event, project)" />
                        </label>
                        <button x-show="project.cover" class={miniBtn + ' !w-auto px-2'} @click="project.cover = ''">retirer</button>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Galerie démo -->
                <div>
                  <label class={label}>Galerie démo</label>
                  <div class="flex flex-wrap gap-2 mb-2">
                    <template x-for="(_, gi) in project.gallery" :key="gi">
                      <div class="relative group/img">
                        <img :src="asset(project.gallery[gi])" alt="" class="w-20 h-14 object-cover rounded-md border border-lab-border" />
                        <button
                          class="absolute -top-2 -right-2 w-5 h-5 rounded-full bg-lab-dark border border-lab-border text-gray-300 hover:text-red-400 hover:border-red-400 text-xs flex items-center justify-center"
                          @click="remove(project.gallery, gi)"
                          title="Supprimer"
                        >✕</button>
                      </div>
                    </template>
                  </div>
                  <div class="flex flex-wrap gap-2 items-center">
                    <label class={addBtn + ' cursor-pointer'}>
                      ⬆ Ajouter des images
                      <input type="file" accept="image/*" multiple class="hidden" @change="uploadGallery($event, project)" />
                    </label>
                    <button class={addBtn} @click="addString(project.gallery)">+ via URL</button>
                  </div>
                  <!-- Édition des URLs de galerie -->
                  <div class="space-y-2 mt-2" x-show="project.gallery.length">
                    <template x-for="(_, gi) in project.gallery" :key="'u' + gi">
                      <div class="flex gap-2">
                        <input class={input} x-model="project.gallery[gi]" placeholder="URL ou /projects/demo.jpg" />
                        <button class={miniBtn} @click="remove(project.gallery, gi)">✕</button>
                      </div>
                    </template>
                  </div>
                </div>
              </div>

              <div class="grid sm:grid-cols-2 gap-4 items-end">
                <div>
                  <label class={label}>Dégradé</label>
                  <div class="flex items-center gap-2">
                    <span class="w-8 h-8 rounded-md shrink-0 border border-lab-border" :class="project.gradient"></span>
                    <select class={input} x-model="project.gradient">
                      <template x-for="(g, gi) in gradients" :key="gi">
                        <option :value="g" x-text="'Preset ' + (gi + 1)"></option>
                      </template>
                    </select>
                  </div>
                </div>
                <label class="flex items-center gap-2 text-sm text-gray-300 py-2">
                  <input type="checkbox" x-model="project.featured" class="accent-neon-cyan" /> ★ Mis en avant
                </label>
              </div>

              <div class="grid sm:grid-cols-2 gap-6">
                <div>
                  <label class={label}>Tags (stack)</label>
                  <div class="flex flex-wrap gap-2">
                    <template x-for="(_, ti) in project.tags" :key="ti">
                      <div class="flex gap-1 items-center">
                        <input class={input + ' !w-28'} x-model="project.tags[ti]" />
                        <button class={miniBtn} @click="remove(project.tags, ti)">✕</button>
                      </div>
                    </template>
                  </div>
                  <button class={addBtn + ' mt-2'} @click="addString(project.tags)">+ tag</button>
                </div>
                <div>
                  <label class={label}>Fonctionnalités clés</label>
                  <div class="space-y-2">
                    <template x-for="(_, fi) in project.features" :key="fi">
                      <div class="flex gap-2">
                        <input class={input} x-model="project.features[fi]" />
                        <button class={miniBtn} @click="remove(project.features, fi)">✕</button>
                      </div>
                    </template>
                  </div>
                  <button class={addBtn + ' mt-2'} @click="addString(project.features)">+ feature</button>
                </div>
              </div>
              </div>
            </div>
          </template>
        </section>

        <!-- ====== LABS ====== -->
        <section x-show="activeTab === 'labs'" style="display:none" class="space-y-5">
          <div class="flex items-center justify-between">
            <h2 class="text-white font-bold">Labs <span class="text-gray-600 text-sm font-mono" x-text="'(' + data.labs.length + ')'"></span></h2>
            <button class={addBtn} @click="addLab()">+ Nouveau labo</button>
          </div>
          <p class="text-gray-500 text-xs font-mono">
            Prototypes, tests d'API, mini-projets et idées en vrac.
          </p>
          <input
            type="search"
            x-model="labQuery"
            placeholder="Rechercher un labo par titre…"
            class={input + ' !max-w-sm'}
          />
          <template x-for="(lab, li) in data.labs" :key="lab.id">
            <div class:list={[card, 'space-y-4']} x-show="matches(lab.title, labQuery)">
              <div class="flex items-start gap-3">
                <div class="flex-1 grid sm:grid-cols-4 gap-4">
                  <div class="sm:col-span-1"><label class={label}>Émoji</label><input class={input} x-model="lab.emoji" placeholder="🔬" /></div>
                  <div class="sm:col-span-3"><label class={label}>Titre</label><input class={input} x-model="lab.title" /></div>
                </div>
                <div class="flex gap-1 pt-5">
                  <button class={miniBtn} @click="move(data.labs, li, -1)">↑</button>
                  <button class={miniBtn} @click="move(data.labs, li, 1)">↓</button>
                  <button class={miniBtn} @click="remove(data.labs, li)">✕</button>
                </div>
              </div>
              <div>
                <label class={label}>Phrase (ce que j'ai testé + appris)</label>
                <textarea rows="2" class={input} x-model="lab.tagline"></textarea>
              </div>
              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label class={label}>Statut</label>
                  <select class={input} x-model="lab.status">
                    <option value="idea">💡 Idée</option>
                    <option value="wip">🧪 En cours</option>
                    <option value="done">✅ Terminé</option>
                  </select>
                </div>
                <div><label class={label}>Lien (démo / repo)</label><input class={input} x-model="lab.url" placeholder="https://..." /></div>
              </div>
              <div>
                <label class={label}>Tags</label>
                <div class="flex flex-wrap gap-2">
                  <template x-for="(_, ti) in lab.tags" :key="ti">
                    <div class="flex gap-1 items-center">
                      <input class={input + ' !w-28'} x-model="lab.tags[ti]" />
                      <button class={miniBtn} @click="remove(lab.tags, ti)">✕</button>
                    </div>
                  </template>
                </div>
                <button class={addBtn + ' mt-2'} @click="addString(lab.tags)">+ tag</button>
              </div>

              <!-- Démo live (façon CodePen) -->
              <div class="border-t border-lab-border pt-4 space-y-3">
                <div class="flex items-center justify-between">
                  <label class={label + ' !mb-0'}>Démo live (HTML / CSS / JS)</label>
                  <span class="text-[10px] font-mono text-gray-600">exécutée dans un iframe isolé</span>
                </div>

                <!-- Aide : librairies / CDN utilisables dans une démo -->
                <details class="bg-lab-dark border border-lab-border rounded-lg text-xs">
                  <summary class="cursor-pointer select-none px-3 py-2 text-neon-cyan font-mono">
                    📦 Utiliser Tailwind, Bootstrap, un CDN… (cliquer)
                  </summary>
                  <div class="px-3 pb-3 pt-1 space-y-2 text-gray-400 leading-relaxed">
                    <p>Ajoute la balise dans le champ <span class="text-white font-mono">HTML</span> :</p>
                    <pre class="bg-black/40 border border-lab-border rounded p-2 overflow-x-auto text-[11px] text-gray-300 font-mono">&lt;script src="https://cdn.tailwindcss.com"&gt;&lt;/script&gt;
&lt;link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"&gt;</pre>
                    <p>
                      <span class="text-gray-300">CDN autorisés</span> (sécurité) —
                      <span class="text-white font-mono">JS</span> : cdn.tailwindcss.com · cdn.jsdelivr.net · unpkg.com · cdnjs.cloudflare.com · code.jquery.com ·
                      <span class="text-white font-mono">CSS</span> : cdn.jsdelivr.net · cdnjs.cloudflare.com · unpkg.com · fonts.googleapis.com
                    </p>
                    <p class="text-gray-500">
                      Astuce : <span class="text-neon-green font-mono">jsdelivr</span> sert n'importe quel package npm →
                      <span class="font-mono">https://cdn.jsdelivr.net/npm/&lt;package&gt;</span>. Pour un autre CDN, demande-le.
                    </p>
                  </div>
                </details>

                <div class="grid lg:grid-cols-2 gap-3">
                  <div class="space-y-3">
                    <div>
                      <label class={label}>HTML</label>
                      <div class="code-editor">
                        <pre aria-hidden="true"><code class="hljs" x-html="$hl(lab.demo.html || '', 'html')"></code></pre>
                        <textarea rows="4" spellcheck="false" x-model="lab.demo.html" @scroll="$el.previousElementSibling.scrollTop = $el.scrollTop" placeholder="<div>…</div>"></textarea>
                      </div>
                    </div>
                    <div>
                      <label class={label}>CSS</label>
                      <div class="code-editor">
                        <pre aria-hidden="true"><code class="hljs" x-html="$hl(lab.demo.css || '', 'css')"></code></pre>
                        <textarea rows="4" spellcheck="false" x-model="lab.demo.css" @scroll="$el.previousElementSibling.scrollTop = $el.scrollTop" placeholder="body { … }"></textarea>
                      </div>
                    </div>
                    <div>
                      <label class={label}>JavaScript</label>
                      <div class="code-editor">
                        <pre aria-hidden="true"><code class="hljs" x-html="$hl(lab.demo.js || '', 'js')"></code></pre>
                        <textarea rows="5" spellcheck="false" x-model="lab.demo.js" @scroll="$el.previousElementSibling.scrollTop = $el.scrollTop" placeholder="const x = …"></textarea>
                      </div>
                    </div>
                  </div>
                  <div>
                    <label class={label}>Aperçu</label>
                    <iframe
                      sandbox="allow-scripts allow-downloads"
                      :srcdoc="labPreview(lab)"
                      class="w-full h-64 rounded-lg border border-lab-border bg-lab-dark"
                      title="Aperçu de la démo"
                    ></iframe>
                  </div>
                </div>
              </div>
            </div>
          </template>
        </section>

        <!-- ====== ARTICLES (BLOG) ====== -->
        <section x-show="activeTab === 'blog'" style="display:none" class="space-y-5">
          <template x-if="!apiAvailable">
            <div class="bg-yellow-500/10 border border-yellow-500/30 rounded-lg p-4 text-yellow-200 text-sm">
              L'édition d'articles nécessite le serveur local (<span class="font-mono">npm run dev</span>).
              En ligne, les articles s'éditent en local puis se publient via <span class="font-mono">git push</span>.
            </div>
          </template>

          <!-- Génération par IA -->
          <template x-if="!editingPost">
            <div class:list={[card, 'space-y-4', 'border-neon-cyan/30']}>
              <button type="button" class="w-full flex items-center justify-between text-left" @click="toggleAi()">
                <span class="text-white font-bold flex items-center gap-2">✨ Générer avec l'IA <span class="text-[11px] font-mono text-gray-500">(dans ton style)</span></span>
                <span class="text-neon-cyan font-mono text-sm" x-text="ai.open ? '−' : '+'"></span>
              </button>

              <div x-show="ai.open" x-cloak class="space-y-4">
                <p class="text-[12px] text-gray-500 leading-relaxed">
                  L'IA rédige un brouillon dans <span class="text-gray-300">ton style</span> (1ʳᵉ personne, point de vue dev, ton blog).
                  Ta clé API reste <span class="text-neon-cyan">en local</span> dans ton navigateur — elle n'est jamais committée, juste relayée par le serveur dev au fournisseur.
                </p>

                <div class="grid sm:grid-cols-2 gap-3">
                  <div>
                    <label class={label}>Fournisseur</label>
                    <select class={input} x-model="ai.provider" @change="onAiProviderChange()">
                      <template x-for="p in aiProviders" :key="p.id">
                        <option :value="p.id" x-text="p.label"></option>
                      </template>
                    </select>
                  </div>
                  <div>
                    <label class={label + ' flex items-center justify-between gap-2'}>
                      <span>Modèle</span>
                      <button type="button" x-show="aiModels.length" x-cloak @click="aiManualModel = !aiManualModel"
                        class="text-[10px] font-mono normal-case tracking-normal text-neon-cyan hover:underline"
                        x-text="aiManualModel ? '← choisir dans la liste' : 'saisir à la main'"></button>
                    </label>
                    <!-- Combobox : modèles réellement dispo pour la clé (chargés via « Tester la clé »). -->
                    <div x-show="aiModels.length && !aiManualModel" x-cloak class="relative" @click.outside="aiModelOpen = false">
                      <input class={input} x-model="aiModelFilter"
                        @focus="aiModelOpen = true" @click="aiModelOpen = true" @input="aiModelOpen = true"
                        :placeholder="ai.model || 'Choisir un modèle…'" autocomplete="off" />
                      <div x-show="aiModelOpen" x-cloak class="absolute z-20 mt-1 w-full max-h-60 overflow-auto bg-lab-dark border border-lab-border rounded-lg shadow-xl">
                        <template x-for="m in filteredAiModels" :key="m">
                          <button type="button" @click="pickAiModel(m)"
                            class="block w-full text-left px-3 py-1.5 text-sm hover:bg-lab-card transition-colors flex items-center justify-between gap-2"
                            :class="m === ai.model ? 'text-neon-cyan' : 'text-gray-300'">
                            <span x-text="m"></span>
                            <span x-show="m === ai.model" class="text-neon-cyan">✓</span>
                          </button>
                        </template>
                        <p x-show="!filteredAiModels.length" class="px-3 py-2 text-xs text-gray-500">Aucun modèle ne correspond.</p>
                      </div>
                    </div>
                    <!-- Saisie libre (aucun modèle chargé, ou mode manuel). -->
                    <input x-show="!aiModels.length || aiManualModel" class={input} x-model="ai.model" @change="persistAi()" :placeholder="aiProvider.defaultModel" />
                    <p class="text-[11px] text-gray-600 mt-1" x-show="!aiModels.length" x-text="aiProvider.modelHint"></p>
                    <p class="text-[11px] mt-1" x-show="aiModels.length && !aiManualModel" x-cloak>
                      <span class="text-gray-500">Sélectionné :</span> <span class="text-neon-green font-mono" x-text="ai.model || '—'"></span>
                      <span class="text-gray-600" x-text="' (' + aiModels.length + ' dispo)'"></span>
                    </p>
                  </div>
                </div>

                <div>
                  <label class={label + ' flex items-center gap-2'}>
                    Clé API <span class="text-neon-cyan normal-case tracking-normal" x-text="'(' + aiProvider.label + ')'"></span>
                    <span class="text-[10px] font-mono text-neon-green/80 normal-case tracking-normal">🔒 chiffrée (AES) avec ta phrase d'accès</span>
                  </label>
                  <input type="password" class={input + ' font-mono'} x-model="ai.apiKeys[ai.provider]" @change="onAiKeyChange()" placeholder="sk-…" autocomplete="off" />
                  <p x-show="aiKeyLocked && !aiKey" x-cloak class="text-[11px] text-yellow-300/80 mt-1">
                    🔒 Une clé chiffrée est mémorisée mais la phrase d'accès de cette session ne l'ouvre pas. Recolle ta clé (elle sera rechiffrée).
                  </p>
                  <p class="text-[11px] text-gray-600 mt-1">
                    Stockée chiffrée en local, jamais committée. Obtenir une clé :
                    <a :href="aiProvider.keyUrl" target="_blank" rel="noopener" class="text-neon-cyan hover:underline" x-text="aiProvider.keyUrl"></a>
                  </p>
                  <div class="flex flex-wrap items-center gap-3 mt-2">
                    <button type="button" class={addBtn} @click="testAiKey()" :disabled="aiTest.busy || !apiAvailable">
                      <span x-show="!aiTest.busy">🔑 Tester la clé &amp; charger les modèles</span>
                      <span x-show="aiTest.busy" x-cloak>⏳ Test…</span>
                    </button>
                    <span x-show="aiTest.msg" x-cloak class="text-sm" :class="aiTest.ok ? 'text-neon-green' : 'text-red-300'" x-text="aiTest.msg"></span>
                  </div>
                </div>

                <div class="flex flex-wrap gap-4">
                  <label class="flex items-center gap-2 text-sm text-gray-300 cursor-pointer" :class="!aiProvider.webSearch && 'opacity-40 cursor-not-allowed'">
                    <input type="checkbox" x-model="ai.webSearch" :disabled="!aiProvider.webSearch" @change="persistAi()" class="accent-neon-cyan" />
                    Recherche web <span class="text-[11px] text-gray-600" x-show="!aiProvider.webSearch">(indispo pour ce fournisseur)</span>
                  </label>
                  <label class="flex items-center gap-2 text-sm text-gray-300 cursor-pointer">
                    <input type="checkbox" x-model="ai.cover" @change="persistAi()" class="accent-neon-cyan" />
                    Générer une couverture néon
                  </label>
                </div>

                <div>
                  <label class={label}>Sujet (pour « depuis un sujet ») / orientation (optionnelle pour « tendance »)</label>
                  <textarea rows="2" class={input} x-model="ai.topic" placeholder="ex. Le edge computing pour les apps mobiles en 2026…"></textarea>
                </div>

                <div x-show="ai.error" x-cloak class="bg-red-500/10 border border-red-500/30 rounded-lg p-3 text-red-300 text-sm" x-text="ai.error"></div>

                <div class="flex flex-wrap gap-3 items-center">
                  <button class={addBtn} @click="generateArticle('topic')" :disabled="ai.busy || !apiAvailable">
                    <span x-show="!ai.busy">🪄 Depuis ce sujet</span>
                    <span x-show="ai.busy" x-cloak>⏳ Génération…</span>
                  </button>
                  <button class={addBtn} @click="generateArticle('trends')" :disabled="ai.busy || !apiAvailable">
                    <span x-show="!ai.busy">📡 Tendance du moment</span>
                    <span x-show="ai.busy" x-cloak>⏳ Génération…</span>
                  </button>
                  <span class="text-[11px] text-gray-600">Le brouillon s'ouvre dans l'éditeur — rien n'est publié sans ton enregistrement.</span>
                </div>
              </div>
            </div>
          </template>

          <!-- Liste des articles -->
          <template x-if="!editingPost">
            <div class="space-y-4">
              <div class="flex items-center justify-between">
                <h2 class="text-white font-bold">Articles <span class="text-gray-600 text-sm font-mono" x-text="'(' + posts.length + ')'"></span></h2>
                <button class={addBtn} @click="newPost()" :disabled="!apiAvailable">+ Nouvel article</button>
              </div>
              <template x-if="posts.length === 0">
                <p class="text-gray-500 text-sm font-mono">Aucun article. Crée le premier !</p>
              </template>
              <template x-for="post in posts" :key="post.slug">
                <div class:list={[card, 'flex items-center gap-4']}>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2">
                      <span class="text-white font-bold truncate" x-text="post.data.title"></span>
                      <span x-show="post.data.draft" class="px-1.5 py-0.5 rounded bg-yellow-300/10 border border-yellow-300/30 text-yellow-300 text-[10px] font-mono">brouillon</span>
                    </div>
                    <div class="text-gray-500 text-xs font-mono mt-1" x-text="post.data.date + ' · /blog/' + post.slug"></div>
                  </div>
                  <button class={miniBtn} @click="editPost(post)" title="Modifier">✎</button>
                  <button class={miniBtn} @click="deletePost(post.slug)" title="Supprimer">✕</button>
                </div>
              </template>
            </div>
          </template>

          <!-- Éditeur d'article -->
          <template x-if="editingPost">
            <div class="space-y-4">
              <div class="flex items-center justify-between">
                <h2 class="text-white font-bold" x-text="postDraft.originalSlug ? 'Modifier l’article' : 'Nouvel article'"></h2>
                <div class="flex gap-2">
                  <button class={miniBtn + ' !w-auto px-3'} @click="cancelPost()">Annuler</button>
                  <button class={addBtn} @click="savePost()" :disabled="postBusy">💾 Enregistrer</button>
                </div>
              </div>

              <div class="grid lg:grid-cols-2 gap-4">
                <!-- Colonne gauche : métadonnées + markdown -->
                <div class="space-y-3">
                  <div><label class={label}>Titre</label><input class={input} x-model="postDraft.title" /></div>
                  <div>
                    <label class={label}>Slug (URL)</label>
                    <div class="flex items-center gap-2 text-xs font-mono text-gray-500">
                      <span>/blog/</span>
                      <input class={input} x-model="postDraft.slug" :placeholder="postSlug" />
                    </div>
                    <p class="text-[11px] text-gray-600 mt-1">Laisse vide pour générer depuis le titre : <span class="text-neon-cyan" x-text="postSlug"></span></p>
                  </div>
                  <div><label class={label}>Description</label><textarea rows="2" class={input} x-model="postDraft.description"></textarea></div>
                  <div class="grid grid-cols-2 gap-3">
                    <div><label class={label}>Date</label><input type="date" class={input} x-model="postDraft.date" /></div>
                    <div class="flex items-end pb-1">
                      <label class="flex items-center gap-2 text-sm text-gray-300 cursor-pointer">
                        <input type="checkbox" x-model="postDraft.draft" class="accent-neon-cyan" />
                        Brouillon
                      </label>
                    </div>
                  </div>
                  <div>
                    <label class={label}>Tags</label>
                    <div class="flex flex-wrap gap-2">
                      <template x-for="(_, ti) in postDraft.tags" :key="ti">
                        <div class="flex gap-1 items-center">
                          <input class={input + ' !w-28'} x-model="postDraft.tags[ti]" />
                          <button class={miniBtn} @click="remove(postDraft.tags, ti)">✕</button>
                        </div>
                      </template>
                    </div>
                    <button class={addBtn + ' mt-2'} @click="addString(postDraft.tags)">+ tag</button>
                  </div>
                  <div>
                    <label class={label}>Couverture</label>
                    <div class="flex items-center gap-3">
                      <template x-if="postDraft.cover">
                        <img :src="asset(postDraft.cover)" alt="" class="w-24 h-14 object-cover rounded border border-lab-border" />
                      </template>
                      <label class={miniBtn + ' !w-auto px-3 cursor-pointer'}>
                        📁
                        <input type="file" accept="image/*" class="hidden" @change="uploadPostCover($event)" />
                      </label>
                      <input class={input} x-model="postDraft.cover" placeholder="/blog/cover.webp ou URL" />
                    </div>
                  </div>
                  <div>
                    <label class={label}>Contenu (Markdown)</label>
                    <textarea rows="16" spellcheck="false" class={input + ' font-mono !text-xs leading-relaxed'} x-model="postDraft.body"></textarea>
                  </div>
                </div>

                <!-- Colonne droite : aperçu live (sticky pendant le scroll) -->
                <div class="lg:sticky lg:top-24 self-start">
                  <label class={label}>Aperçu</label>
                  <div class="bg-lab-dark border border-lab-border rounded-lg p-5 h-[640px] lg:h-[calc(100vh-11rem)] overflow-auto">
                    <article class="prose-lab" x-html="postPreviewHtml"></article>
                  </div>
                  <p class="text-[11px] text-gray-600 mt-2">Aperçu fidèle (maths incluses). La coloration syntaxique du code apparaît sur le site publié.</p>
                </div>
              </div>
            </div>
          </template>
        </section>

        <!-- ====== PARCOURS ====== -->
        <section x-show="activeTab === 'experience'" style="display:none" class="space-y-5">
          <div class="flex items-center justify-between">
            <h2 class="text-white font-bold">Parcours</h2>
            <button class={addBtn} @click="addExperience()">+ Expérience</button>
          </div>
          <template x-for="(exp, ei) in data.experience" :key="exp.id">
            <div class:list={[card, 'space-y-4']}>
              <div class="flex items-start gap-3">
                <div class="flex-1 grid sm:grid-cols-2 gap-4">
                  <div><label class={label}>Poste</label><input class={input} x-model="exp.role" /></div>
                  <div><label class={label}>Entreprise</label><input class={input} x-model="exp.company" /></div>
                  <div><label class={label}>Période</label><input class={input} x-model="exp.period" placeholder="2023 — Présent" /></div>
                </div>
                <div class="flex gap-1 pt-5">
                  <button class={miniBtn} @click="move(data.experience, ei, -1)">↑</button>
                  <button class={miniBtn} @click="move(data.experience, ei, 1)">↓</button>
                  <button class={miniBtn} @click="remove(data.experience, ei)">✕</button>
                </div>
              </div>
              <div><label class={label}>Description</label><textarea rows="3" class={input} x-model="exp.description"></textarea></div>
              <div>
                <label class={label}>Technologies</label>
                <div class="flex flex-wrap gap-2">
                  <template x-for="(_, ti) in exp.tech" :key="ti">
                    <div class="flex gap-1 items-center">
                      <input class={input + ' !w-28'} x-model="exp.tech[ti]" />
                      <button class={miniBtn} @click="remove(exp.tech, ti)">✕</button>
                    </div>
                  </template>
                </div>
                <button class={addBtn + ' mt-2'} @click="addString(exp.tech)">+ techno</button>
              </div>
            </div>
          </template>
        </section>

        <!-- ====== CONTACT ====== -->
        <section x-show="activeTab === 'contact'" style="display:none" class:list={[card, 'space-y-4']}>
          <h2 class="text-white font-bold">Contact & réseaux</h2>
          <div><label class={label}>Intro</label><textarea rows="2" class={input} x-model="data.contact.intro"></textarea></div>
          <div class="grid sm:grid-cols-2 gap-4">
            <div><label class={label}>Email</label><input class={input} x-model="data.contact.email" /></div>
            <div><label class={label}>Téléphone (CV)</label><input class={input} x-model="data.contact.phone" placeholder="+261 ..." /></div>
            <div><label class={label}>Localisation</label><input class={input} x-model="data.contact.location" /></div>
            <div><label class={label}>Statut</label><input class={input} x-model="data.contact.status" /></div>
            <div><label class={label}>Endpoint Formspree (option.)</label><input class={input} x-model="data.contact.formEndpoint" placeholder="https://formspree.io/f/xxxx" /></div>
          </div>
          <div class="bg-lab-dark border border-lab-border rounded-lg p-4">
            <label class={label}>Clé Web3Forms (recevoir les messages par email — gratuit)</label>
            <input class={input} x-model="data.contact.web3formsKey" placeholder="Ex: 1a2b3c4d-...." />
            <p class="text-[11px] text-gray-500 mt-2 leading-relaxed">
              En production, c'est le <span class="text-neon-cyan">secret GitHub WEB3FORMS_KEY</span> qui est utilisé (hors du dépôt).
              Ce champ sert de repli (ex. dev local). Sans clé ni Formspree, le formulaire ouvre le client mail du visiteur.
            </p>
          </div>
          <h3 class="text-gray-400 text-sm font-mono pt-2">Réseaux (sidebar)</h3>
          <div class="grid sm:grid-cols-3 gap-4">
            <div><label class={label}>GitHub</label><input class={input} x-model="data.socials.github" /></div>
            <div><label class={label}>LinkedIn</label><input class={input} x-model="data.socials.linkedin" /></div>
            <div><label class={label}>Email (icône)</label><input class={input} x-model="data.socials.email" /></div>
          </div>

          <h3 class="text-gray-400 text-sm font-mono pt-2">Statistiques de visite</h3>
          <div class="bg-lab-dark border border-lab-border rounded-lg p-4">
            <label class={label}>Token Cloudflare Web Analytics (gratuit, sans cookies)</label>
            <input class={input} x-model="data.analytics.cloudflareToken" placeholder="Ex: 1a2b3c4d5e6f..." />
            <p class="text-[11px] text-gray-500 mt-2 leading-relaxed">
              En production, c'est le <span class="text-neon-cyan">secret GitHub CF_ANALYTICS_TOKEN</span> qui est utilisé (hors du dépôt).
              Token depuis Cloudflare → Analytics &amp; Logs → Web Analytics → Add a site.
              Les stats ne se chargent qu'<span class="text-neon-green">en production</span> (pas en local).
            </p>
          </div>
        </section>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ seed: content }}>
    window.__ADMIN_SEED__ = seed;
  </script>
  <script>
    import "../scripts/admin";
  </script>
</Base>

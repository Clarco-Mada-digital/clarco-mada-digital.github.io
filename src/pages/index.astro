---
import Base from "../layouts/Base.astro";
import Sidebar from "../components/Sidebar.astro";
import Home from "../components/sections/Home.astro";
import About from "../components/sections/About.astro";
import Skills from "../components/sections/Skills.astro";
import Projects from "../components/sections/Projects.astro";
import Labs from "../components/sections/Labs.astro";
import Experience from "../components/sections/Experience.astro";
import Contact from "../components/sections/Contact.astro";
import ProjectModal from "../components/ProjectModal.astro";
import LabModal from "../components/LabModal.astro";
import CvModal from "../components/CvModal.astro";
import CustomizePanel from "../components/CustomizePanel.astro";
import CommandPalette from "../components/CommandPalette.astro";
import Toasts from "../components/Toasts.astro";
import { content } from "../lib/content";

const { site, hero, contact } = content;

// Données injectées dans Alpine (modale projet + formulaire + typewriter).
// Clé Web3Forms : priorité au champ admin (content.json), sinon secret GitHub.
// On privilégie l'admin pour que la clé soit gérable sans toucher au code/secret.
// NB : sur un site statique, la valeur finit de toute façon dans le JS livré
// (clé publique par conception).
const web3formsKey = contact.web3formsKey || process.env.WEB3FORMS_KEY || "";

const bootstrap = {
  projects: content.projects,
  tagline: hero.tagline,
  formEndpoint: contact.formEndpoint || "",
  email: contact.email,
  web3formsKey,
  base: import.meta.env.BASE_URL,
  content, // contenu complet, utilisé pour générer le CV PDF
};
---

<Base>
  <div
    x-data="portfolioApp"
    x-effect="document.body.style.overflow = (selectedProject || selectedLab || mobileMenuOpen || paletteOpen) ? 'hidden' : ''"
    @keydown.meta.k.window.prevent="togglePalette()"
    @keydown.ctrl.k.window.prevent="togglePalette()"
    @keydown.slash.window="!paletteOpen && $event.target === document.body && (togglePalette(), $event.preventDefault())"
    class="min-h-screen flex flex-col md:flex-row"
  >
    <Sidebar />

    <!-- ================= MAIN CONTENT ================= -->
    <main class="flex-1 p-6 md:p-12 overflow-y-auto flex flex-col min-h-screen">
      <!-- Zone de contenu : grandit pour pousser le footer en bas -->
      <div class="flex-1">
        <!-- Indicateur de navigation -->
        <div class="font-mono text-xs text-gray-600 mb-8 flex items-center gap-2">
          <span class="text-neon-purple">~/{site.handle}</span>
          <span>/</span>
          <span class="text-neon-cyan" x-text="activeView"></span>
          <span class="cursor"></span>
        </div>

        <Home />
        <About />
        <Skills />
        <Projects />
        <Labs />
        <Experience />
        <Contact />
      </div>

      <!-- Footer mini : toujours collé en bas (mt-auto) -->
      <footer
        class="mt-auto pt-8 border-t border-lab-border text-center text-xs text-gray-600 font-mono"
      >
        <p>
          Conçu et développé avec ❤️ par {site.name} — Astro, Alpine.js & Tailwind
          CSS
        </p>
      </footer>
    </main>

    <ProjectModal />
    <LabModal />
    <CvModal />
    <CustomizePanel />
    <CommandPalette />
    <Toasts />
  </div>

  <script
    is:inline
    define:vars={{ bootstrap }}
  >
    window.__PORTFOLIO__ = bootstrap;
  </script>
  <script>
    import "../scripts/portfolio";
  </script>
  <!-- Accès caché à la console (Konami code / triple-clic logo) -->
  <script>
    import "../scripts/secret";
  </script>
</Base>
